@page "/abc"
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using global::ProductCatalog.Models
@using global::ProductCatalog.Services
@inject ProductService ProductService

<PageTitle>Dashboard</PageTitle>

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>Dashboard</h1>
        <button class="refresh-btn" @onclick="RefreshData">Refresh Data</button>
    </div>

    <div class="kpi-cards">
        <!-- KPI Cards -->
        <div class="kpi-card">
            <h3>Total Products</h3>
            <p class="kpi-value">@Products.Count</p>
        </div>
        <div class="kpi-card">
            <h3>Low Stock Products</h3>
            <p class="kpi-value">@LowStockProducts.Count</p>
        </div>
        <div class="kpi-card">
            <h3>Total Categories</h3>
            <p class="kpi-value">@CategoryCount</p>
        </div>
    </div>

    <!-- Category Distribution Chart -->
    <div class="chart-card">
        <h3>Product Distribution by Category</h3>
        <TelerikChart>
            @* Global Tooltip Settings *@
            <ChartTooltip Visible="true" Shared="true" />

            <ChartSeriesItems>
                <ChartSeries Type="ChartSeriesType.Pie"
                             Name="Products by Category"
                             Data="@CategoryChartData"
                             Field="Count"
                             CategoryField="Category">

                    <ChartSeriesTooltip Visible="true">
                        <Template>
                            @{
                                var dataItem = context.DataItem as dynamic;
                                <div>
                                    <strong>@dataItem.Category</strong><br />
                                    Total Products: @dataItem.Count
                                </div>
                            }
                        </Template>
                    </ChartSeriesTooltip>
                </ChartSeries>
            </ChartSeriesItems>

            <ChartLegend Position="ChartLegendPosition.Right" />
        </TelerikChart>
    </div>

    <!-- Low Stock Products Table -->
    <div class="chart-card">
        <h3>Low Stock Products</h3>
        <TelerikGrid Data="@LowStockProducts" Pageable="true" Sortable="true" PageSize="5">
            <GridColumns>
                <GridColumn Field="@nameof(Product.Name)" Title="Product Name" />
                <GridColumn Field="@nameof(Product.Category)" Title="Category" />
                <GridColumn Field="@nameof(Product.Stock)" Title="Stock" />
            </GridColumns>
        </TelerikGrid>
    </div>
</div>

@code {
    private List<Product> Products = new();
    private List<Product> LowStockProducts => Products.Where(p => p.Stock <= 5).ToList();
    private int CategoryCount => Products.Select(p => p.Category).Distinct().Count();

    private IEnumerable<object> CategoryChartData =>
        Products.GroupBy(p => p.Category)
                .Select(g => new { Category = g.Key, Count = g.Count() })
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        Products = await ProductService.GetProductsAsync();
    }

    private async Task RefreshData()
    {
        Products = await ProductService.GetProductsAsync();
    }
}

<style>
    .dashboard-container {
        padding: 20px;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

        .dashboard-header h1 {
            font-size: 2rem;
            color: #333;
        }

    .refresh-btn {
        padding: 8px 16px;
        background-color: #0078D4;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1rem;
    }

        .refresh-btn:hover {
            background-color: #005a99;
        }

    .kpi-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
    }

    .kpi-card {
        background: #ffffff;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.1);
        text-align: center;
    }

        .kpi-card h3 {
            font-size: 1.25rem;
            margin-bottom: 10px;
        }

    .kpi-value {
        font-size: 2rem;
        font-weight: bold;
        color: #0078D4;
    }

    .chart-card {
        background: #ffffff;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.1);
    }
</style>
