@page "/analytics"
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using global::ProductCatalog.Models
@using global::ProductCatalog.Services
@inject ProductService ProductService

<PageTitle>Analytics</PageTitle>

<div class="analytics-container">
    <div class="analytics-header">
        <h2>Analytics Dashboard</h2>
    </div>

    <!-- Category-wise Products Chart -->
    <div class="chart-card">
        <h3>Products per Category</h3>
        <TelerikChart OnSeriesClick="@OnSeriesClick">
            <ChartSeriesItems>
                <ChartSeries Type="ChartSeriesType.Column"
                             Name="Products"
                             Data="@CategoryChartData"
                             Field="Count"
                             CategoryField="Category">
                </ChartSeries>
            </ChartSeriesItems>

            <ChartCategoryAxes>
                <ChartCategoryAxis>
                    <ChartCategoryAxisLabels>
                        <ChartCategoryAxisLabelsRotation Angle="-45" />
                    </ChartCategoryAxisLabels>
                </ChartCategoryAxis>
            </ChartCategoryAxes>
        </TelerikChart>
    </div>


    <!-- Products Drill-down Table -->
    @if (SelectedCategoryProducts.Any())
    {
        <div class="chart-card">
            <h3>Products in Category: @SelectedCategory</h3>
            <TelerikGrid Data="@SelectedCategoryProducts"
                         Pageable="true"
                         Sortable="true"
                         PageSize="5">
                <GridColumns>
                    <GridColumn Field="@nameof(Product.Name)" Title="Product Name" />
                    <GridColumn Field="@nameof(Product.Category)" Title="Category" />
                    <GridColumn Field="@nameof(Product.Price)" Title="Price">
                        <Template Context="p">@((p as Product)?.Price.ToString("C"))</Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(Product.Stock)" Title="Stock" />
                    <GridColumn Title="Image" Width="100px">
                        <Template Context="p">
                            <img src="@ProductImages[((Product)p).Id]" class="product-image" />
                        </Template>
                    </GridColumn>
                </GridColumns>
            </TelerikGrid>
        </div>
    }
    <!-- Stock Level Trend Chart -->
    <div class="chart-card">
        <h3>Stock Levels Over Time</h3>
        <TelerikChart>
            <ChartSeriesItems>
                <ChartSeries Type="ChartSeriesType.Line"
                             Name="Stock Level"
                             Data="@StockLevelTrendData"
                             Field="Stock"
                             CategoryField="Date">
                </ChartSeries>
            </ChartSeriesItems>
            <ChartCategoryAxes>
                <ChartCategoryAxis>
                    <ChartCategoryAxisLabels>
                        <ChartCategoryAxisLabelsRotation Angle="-45" />
                    </ChartCategoryAxisLabels>
                </ChartCategoryAxis>
            </ChartCategoryAxes>
        </TelerikChart>
    </div>

</div>

@code {
    private List<Product> Products = new();
    private string SelectedCategory = "";
    private List<Product> SelectedCategoryProducts = new();
    private Dictionary<int, string> ProductImages = new();

    // Category-wise chart data
    private IEnumerable<object> CategoryChartData =>
        Products.GroupBy(p => p.Category)
                .Select(g => new { Category = g.Key, Count = g.Count() })
                .ToList();

    // Flattened Stock Levels Over Time
    private IEnumerable<object> StockLevelTrendData =>
        Products.SelectMany(p => GetSimulatedStockData(p, p.Name)).ToList();

    // Simulate Stock Level Data Over the Last 6 Months
    private IEnumerable<object> GetSimulatedStockData(Product product, string productName)
    {
        var trendData = new List<object>();
        for (int i = 0; i < 6; i++) // 6 months of data
        {
            trendData.Add(new { Date = DateTime.Now.AddMonths(-i).ToString("MMM yyyy"), Stock = product.Stock + (i * 5), ProductName = productName });
        }
        return trendData;
    }

    protected override async Task OnInitializedAsync()
    {
        Products = await ProductService.GetProductsAsync();

        // Populate ProductImages dictionary
        var response = await ProductService.GetRawDummyProductsAsync();
        foreach (var p in response.products)
        {
            ProductImages[p.id] = p.thumbnail ?? "";
        }
    }

    private void OnSeriesClick(ChartSeriesClickEventArgs e)
    {
        SelectedCategory = e.Category?.ToString() ?? "";
        SelectedCategoryProducts = Products.Where(p => p.Category == SelectedCategory).ToList();
    }
}

<style>
    .analytics-container {
        padding: 20px;
    }

    .analytics-header {
        margin-bottom: 20px;
    }

        .analytics-header h2 {
            font-size: 2rem;
            color: #333;
        }

    .chart-card {
        background: #ffffff;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.1);
        margin-bottom: 24px;
    }

    .product-image {
        border-radius: 4px;
        width: 50px;
        height: auto;
        transition: transform 0.3s ease;
    }

        .product-image:hover {
            transform: scale(1.1);
        }
</style>
