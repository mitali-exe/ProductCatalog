    };

    private string GetAxisLabelFormat() => SelectedInterval switch
    {
        "1s" or "5s" or "10s" or "20s" or "30s" => "HH:mm:ss",
        "1m" or "5m" or "10m" or "20m" or "30m" => "HH:mm",
        "1d" => "MM/dd",
        "1y" => "yyyy",
        _ => "HH:mm"
    };

    private async Task OnIntervalChanged(object args)
    {
        RegroupData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnXAxisChanged(object args)
    {
        SelectedYAxes = new List<string>();
        await LoadData();
        if (SelectedXAxis == "Time")
        {
            await LoadInitialTimeData();
        }

        await InvokeAsync(StateHasChanged);
    }

    private ChartSeriesType GetChartSeriesType()
    {
        return SelectedChartType switch
        {
            "Line" => ChartSeriesType.Line,
            "Bar" => ChartSeriesType.Bar,
            "Area" => ChartSeriesType.Area,
            _ => ChartSeriesType.Column
        };
    }

    private ChartSeriesType GetTrendlineSeriesType()
    {
        return ChartSeriesType.LinearTrendline;
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }

