    private List<string> GetDistinctYAxes()
    {
        var axes = new List<string>();

        foreach (var y in SelectedYAxes)
        {
            if (!axes.Contains(y))
                axes.Add(y);
        }

        foreach (var key in YAxisConfigs.Keys)
        {
            if (!axes.Contains(key))
                axes.Add(key);
        }

        return axes;
    }

    private async Task OnSelectedYAxesChanged(List<string> values)
    {
        var newSelection = values ?? new List<string>();

        // determine removed series (present in configs but not in new selection)
        var removed = SeriesConfigs.Keys.Except(newSelection).ToList();

        foreach (var key in removed)
        {
            SeriesConfigs.Remove(key);
            YAxisConfigs.Remove(key);
            HiddenSeries.Remove(key);
            HiddenSeries.Remove($"{key} Trend");
        }

        // update SelectedYAxes and force chart refresh
        SelectedYAxes = newSelection;
        _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    private YAxisConfiguration GetYAxisConfig(string axisId)
    {
        if (!YAxisConfigs.ContainsKey(axisId))
        {
            var cfg = new YAxisConfiguration
            {
                Name = axisId,
                Title = axisId
            };

            cfg.Position = "Left";

            YAxisConfigs[axisId] = cfg;
        }

        return YAxisConfigs[axisId];
    }

