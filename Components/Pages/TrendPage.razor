    private string GetRenameBuffer(string tag)
    {
        if (!SeriesRenameBuffers.TryGetValue(tag, out var val))
        {
            val = SeriesConfigs.TryGetValue(tag, out var cfg) ? (cfg.Name ?? tag) : tag;
            SeriesRenameBuffers[tag] = val;
        }
        return SeriesRenameBuffers[tag];
    }

    private void SetRenameBuffer(string tag, string value)
    {
        SeriesRenameBuffers[tag] = value ?? "";
    }

