    // Generate visually distinct default color per series index using golden-angle hue spacing.
    private string GetDefaultColor(int index)
    {
        double hue = (index * 137.508) % 360.0;
        return HslToHex(hue, 0.65, 0.55);
    }

    private static string HslToHex(double h, double s, double l)
    {
        h = h % 360;
        double c = (1 - Math.Abs(2 * l - 1)) * s;
        double x = c * (1 - Math.Abs((h / 60.0) % 2 - 1));
        double m = l - c / 2.0;
        double r1 = 0, g1 = 0, b1 = 0;

        if (h < 60) { r1 = c; g1 = x; b1 = 0; }
        else if (h < 120) { r1 = x; g1 = c; b1 = 0; }
        else if (h < 180) { r1 = 0; g1 = c; b1 = x; }
        else if (h < 240) { r1 = 0; g1 = x; b1 = c; }
        else if (h < 300) { r1 = x; g1 = 0; b1 = c; }
        else { r1 = c; g1 = 0; b1 = x; }

        int r = (int)Math.Round((r1 + m) * 255.0);
        int g = (int)Math.Round((g1 + m) * 255.0);
        int b = (int)Math.Round((b1 + m) * 255.0);

        r = Math.Clamp(r, 0, 255);
        g = Math.Clamp(g, 0, 255);
        b = Math.Clamp(b, 0, 255);

        return $"#{r:X2}{g:X2}{b:X2}";
    }

    private string GetDefaultColorFromName(string name) => GetDefaultColor(Math.Abs(name.GetHashCode()) % 360);


    private string GetSeriesColor(string seriesName)
    {
        if (string.IsNullOrEmpty(seriesName))
            return TooltipBackground ?? "#ffffff";

        if (SeriesConfigs.TryGetValue(seriesName, out var cfg) && !string.IsNullOrEmpty(cfg.Color))
            return cfg.Color;

        return GetDefaultColorFromName(seriesName);
    }

    private string GetContrastingTextColor(string hexColor)
    {
        if (string.IsNullOrWhiteSpace(hexColor)) return "#000000";

        var c = hexColor.TrimStart('#');
        if (c.Length == 3)
            c = string.Concat(c[0], c[0], c[1], c[1], c[2], c[2]);

        if (c.Length != 6) return "#000000";

        int r = int.Parse(c.Substring(0, 2), System.Globalization.NumberStyles.HexNumber);
        int g = int.Parse(c.Substring(2, 2), System.Globalization.NumberStyles.HexNumber);
        int b = int.Parse(c.Substring(4, 2), System.Globalization.NumberStyles.HexNumber);

        double luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255.0;
        return luminance > 0.6 ? "#000000" : "#ffffff";
    }


    private bool IsStackSupported(string chartType)
    {
        return chartType is "Line" or "Area" or "Bar" or "Column";
    }

