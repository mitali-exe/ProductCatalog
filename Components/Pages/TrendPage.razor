@page "/"
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using System.Timers
@using Microsoft.EntityFrameworkCore
@using Telerik.SvgIcons
@using global::ProductCatalog.Models
@using static Telerik.Blazor.ThemeConstants.Button
@inject IDbContextFactory<AppDbContext> DbFactory
@implements IDisposable

<!-- ================= MAIN LAYOUT ================= -->
<div class="chart-studio">

    <!-- LEFT SIDEBAR: Configuration Panel -->
    <div class="config-sidebar @(IsConfigCollapsed ? "collapsed" : "")">
        <div class="sidebar-header">
            @if (!IsConfigCollapsed)
            {
                <h4>
                    <TelerikSvgIcon Icon="@SvgIcon.Gear" />
                    Chart Studio
                </h4>
            }
            <TelerikButton FillMode="flat"
                           Icon="@(IsConfigCollapsed ? SvgIcon.ArrowRight : SvgIcon.ArrowLeft)"
                           OnClick="@(() => IsConfigCollapsed = !IsConfigCollapsed)" />
        </div>

        @if (!IsConfigCollapsed)
        {
            <div class="sidebar-body">
                <!-- TABS for organized settings -->
                <TelerikTabStrip @bind-ActiveTabIndex="ActiveConfigTab"
                                 TabPosition="TabPosition.Top">

                    <!-- ===== TAB 1: DATA ===== -->
                    <TabStripTab Title="Data">
                        <div class="config-section">
                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.Table" /> Data Source (Tags)
                            </div>

                            <div class="config-row">
                                <label>Tags</label>
                                <TelerikMultiSelect Data="@TagOptions"
                                                    TextField="Text"
                                                    ValueField="Value"
                                                    Value="@SelectedTags"
                                                    ValueChanged="@((List<string> vals) => OnSelectedTagsChanged(vals))"
                                                    Placeholder="Select tags..."
                                                    Width="100%"
                                                    AutoClose="false" />
                            </div>

                            <div class="config-row">
                                <label>Time Range</label>
                                <div class="range-buttons">
                                    @foreach (var range in RangePresets)
                                    {
                                        <TelerikButton ThemeColor="@(SelectedRange == range.Value ? ThemeColor.Primary : ThemeColor.Base)"
                                                       Size="sm"
                                                       OnClick="@(() => ChangeRange(range.Value))">
                                            @range.Text
                                        </TelerikButton>
                                    }
                                </div>
                            </div>

                            <div class="config-row">
                                <label>
                                    Refresh Interval:
                                </label>

                                <TelerikDropDownList Data="@RefreshIntervalOptions"
                                                     @bind-Value="RefreshIntervalMs"
                                                     Width="100%" />
                                <small class="text-muted">Current: <b>@RefreshIntervalMs ms</b></small>
                            </div>
                        </div>
                    </TabStripTab>

                    <!-- ===== TAB 2: SERIES ===== -->
                    <TabStripTab Title="Series">
                        <div class="config-section">
                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.Graph" /> Series Configuration (per Tag)
                            </div>

                            @if (!SelectedTags.Any())
                            {
                                <div class="empty-state">
                                    <p>Select tags in the Data tab first.</p>
                                </div>
                            }

                            @foreach (var tag in SelectedTags)
                            {
                                var config = GetSeriesConfig(tag);
                                var index = SelectedTags.IndexOf(tag);
                                <div class="series-card @(config.IsHidden ? "hidden-series" : "")">
                                    <div class="series-card-header"
                                         @onclick="@(() => ToggleSeriesExpanded(tag))">
                                        <div class="series-color-dot"
                                             style="background-color: @config.Color;"></div>
                                        <span class="series-name">@(!string.IsNullOrEmpty(config.Name) ? config.Name : tag)</span>
                                        <small class="text-muted" style="margin-left:6px;">@tag</small>
                                        <span class="series-type-badge">@config.ChartType</span>

                                        <div class="series-actions">
                                            <span @onclick:stopPropagation="true">
                                                <TelerikButton FillMode="flat"
                                                               Size="sm"
                                                               Icon="@(config.IsHidden ? SvgIcon.EyeSlash : SvgIcon.Eye)"
                                                               OnClick="@(() => ToggleSeriesVisibility(tag))" />
                                            </span>

                                            <span @onclick:stopPropagation="true">
                                                <TelerikButton FillMode="flat"
                                                               Size="sm"
                                                               Icon="@SvgIcon.ArrowUp"
                                                               OnClick="@(() => MoveSeriesUp(tag))"
                                                               Enabled="@(index > 0)" />
                                            </span>

                                            <span @onclick:stopPropagation="true">
                                                <TelerikButton FillMode="flat"
                                                               Size="sm"
                                                               Icon="@SvgIcon.ArrowDown"
                                                               OnClick="@(() => MoveSeriesDown(tag))"
                                                               Enabled="@(index < SelectedTags.Count - 1)" />
                                            </span>

                                            <TelerikSvgIcon Icon="@(config.IsExpanded? SvgIcon.ChevronUp: SvgIcon.ChevronDown)" />
                                        </div>
                                    </div>

                                    @if (config.IsExpanded)
                                    {
                                        <div class="series-card-body">

                                            <!-- Display Title  -->
                                            <div class="config-row">
                                                <label>Title</label>
                                                <TelerikTextBox Value="@GetRenameBuffer(tag)"
                                                                ValueChanged="@((string v) => { SetRenameBuffer(tag, v); var c = GetSeriesConfig(tag); c.Name = v ?? tag; _chartKey++; StateHasChanged(); })"
                                                                Placeholder="@tag"
                                                                Width="100%" />
                                            </div>

                                            <!-- Chart Type as dropdown -->
                                            <div class="config-row">
                                                <label>Chart Type</label>
                                                <TelerikDropDownList Data="@GetAvailableChartTypes()"
                                                                     TextField="Label"
                                                                     ValueField="Value"
                                                                     Value="@config.ChartType"
                                                                     ValueChanged="@((string v) => SetSeriesChartType(tag, v))"
                                                                     Width="100%" />
                                            </div>

                                            <!-- Color -->
                                            <div class="config-row">
                                                <label>Color</label>
                                                <div class="color-picker-row">
                                                    <input type="color"
                                                           value="@config.Color"
                                                           @onchange="@((ChangeEventArgs e) => SetSeriesColor(tag, e.Value?.ToString()))"
                                                           class="custom-color-input"
                                                           aria-label="@($"Pick color for {tag}")" />
                                                </div>
                                            </div>

                                            <!-- Axis Assignment -->
                                            <div class="config-row">
                                                <label>Y Axis</label>
                                                <div style="display:flex; gap:8px; align-items:center;">
                                                    <TelerikDropDownList Data="@GetYAxisOptions()"
                                                                         TextField="Text"
                                                                         ValueField="Value"
                                                                         Value="@config.AxisName"
                                                                         ValueChanged="@((string v) => SetSeriesAxis(tag, v))"
                                                                         Width="70%" />
                                                    <TelerikButton Size="sm" Icon="@SvgIcon.Plus"
                                                                   OnClick="@(() => AddYAxisForSeries(tag))" />
                                                </div>
                                            </div>

                                            <!-- Line-specific settings -->
                                            @if (config.ChartType is "Line")
                                            {
                                                <div class="config-row">
                                                    <label>Line Style</label>
                                                    <TelerikDropDownList Data="@LineStyles"
                                                                         TextField="Text"
                                                                         ValueField="Value"
                                                                         Value="@config.LineStyle"
                                                                         ValueChanged="@((string v) => config.LineStyle = v)"
                                                                         Width="100%" />
                                                </div>

                                                <div class="config-row">
                                                    <label>Line Width</label>
                                                    <TelerikDropDownList Data="@LineWidthOptions"
                                                                         @bind-Value="config.LineWidth"
                                                                         Width="100%" />
                                                </div>

                                                <div class="config-row inline">
                                                    <label>Smooth Curve</label>
                                                    <TelerikSwitch @bind-Value="config.IsSmooth" />
                                                </div>

                                                <div class="config-row inline">
                                                    <label>Show Markers</label>
                                                    <TelerikSwitch @bind-Value="config.ShowMarkers" />
                                                </div>

                                                @if (config.ShowMarkers)
                                                {
                                                    <div class="config-row">
                                                        <label>Marker Type</label>
                                                        <TelerikDropDownList Data="@MarkerTypes"
                                                                             TextField="Text"
                                                                             ValueField="Value"
                                                                             Value="@config.MarkerType"
                                                                             ValueChanged="@((string v) => config.MarkerType = v)"
                                                                             Width="100%" />
                                                    </div>

                                                    <div class="config-row">
                                                        <label>Marker Size</label>
                                                        <TelerikDropDownList Data="@MarkerSizeOptions"
                                                                             @bind-Value="config.MarkerSize"
                                                                             Width="100%" />
                                                    </div>
                                                }
                                            }

                                            <!-- Data Labels -->
                                            <div class="config-row inline">
                                                <label>Show Data Labels</label>
                                                <TelerikSwitch @bind-Value="config.ShowDataLabels" />
                                            </div>

                                            @if (config.ShowDataLabels)
                                            {
                                                <div class="config-row">
                                                    <label>Label Format</label>
                                                    <TelerikDropDownList Data="@LabelFormats"
                                                                         TextField="Text"
                                                                         ValueField="Value"
                                                                         Value="@config.DataLabelFormat"
                                                                         ValueChanged="@((string v) => config.DataLabelFormat = v)"
                                                                         Width="100%" />
                                                </div>

                                                <div class="config-row">
                                                    <label>Label Position</label>
                                                    <TelerikDropDownList Data="@DataLabelPositions"
                                                                         TextField="Text"
                                                                         ValueField="Value"
                                                                         Value="@config.DataLabelPosition"
                                                                         ValueChanged="@((string v) => config.DataLabelPosition = v)"
                                                                         Width="100%" />
                                                </div>
                                            }

                                            <!-- Trendline -->
                                            <div class="config-row inline">
                                                <label>Show Trendline</label>
                                                <TelerikSwitch @bind-Value="config.ShowTrendline" />
                                            </div>

                                            @if (config.ShowTrendline)
                                            {
                                                <div class="config-row">
                                                    <label>Trendline Type</label>
                                                    <TelerikDropDownList Data="@TrendlineTypes"
                                                                         Value="@config.TrendlineType"
                                                                         ValueChanged="@((string v) => config.TrendlineType = v)"
                                                                         Width="100%" />
                                                </div>

                                                <div class="config-row">
                                                    <label>Trendline Color</label>
                                                    <input type="color"
                                                           value="@config.TrendlineColor"
                                                           @onchange="@((ChangeEventArgs e) => config.TrendlineColor = e.Value?.ToString() ?? "#999")"
                                                           class="custom-color-input" />
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (SelectedTags.Any())
                            {
                                <div class="config-row" style="margin-top: 12px;">
                                    <div class="section-title">
                                        <TelerikSvgIcon Icon="@SvgIcon.AggregateFields" /> Global Series Settings
                                    </div>

                                    <div class="config-row inline">
                                        <label>Stack Series</label>
                                        <TelerikSwitch @bind-Value="IsStacked" />
                                    </div>

                                    @if (IsStacked)
                                    {
                                        <div class="config-row">
                                            <label>Stack Type</label>
                                            <TelerikDropDownList Data="@StackTypes"
                                                                 TextField="Text"
                                                                 ValueField="Value"
                                                                 @bind-Value="SelectedStackType"
                                                                 Width="100%" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </TabStripTab>

                    <!-- ===== TAB 3: X AXIS ===== -->
                    <TabStripTab Title="X Axis">
                        <div class="config-section">

                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.ArrowsLeftRight" /> X Axis (Time)
                            </div>

                            <div class="config-row inline">
                                <label>Show Axis</label>
                                <TelerikSwitch @bind-Value="XAxisConfig.Visible" />
                            </div>

                            <div class="config-row">
                                <label>Title</label>
                                <TelerikTextBox @bind-Value="XAxisConfig.Title"
                                                Placeholder="Time"
                                                Width="100%" />
                            </div>

                            <div class="config-row">
                                <label>Label Rotation</label>
                                <TelerikDropDownList Data="@LabelRotationOptions"
                                                     @bind-Value="CategoryLabelRotation"
                                                     Width="100%" />
                                <small class="text-muted">@CategoryLabelRotation°</small>
                            </div>

                            <div class="config-row">
                                <label>Axis Color</label>
                                <input type="color"
                                       value="@XAxisConfig.AxisColor"
                                       @onchange="@((ChangeEventArgs e) => XAxisConfig.AxisColor = e.Value?.ToString() ?? "#000")"
                                       class="custom-color-input" />
                            </div>

                            <!-- Major Ticks -->
                            <div class="tick-group">
                                <div class="config-row inline">
                                    <label><strong>Major Ticks</strong></label>
                                    <TelerikSwitch @bind-Value="ShowMajorTicks" />
                                </div>

                                @if (ShowMajorTicks)
                                {
                                    <div class="config-row">
                                        <label>Step</label>
                                        <TelerikNumericTextBox @bind-Value="MajorTickStep"
                                                               Min="1" Max="100" Step="1"
                                                               Width="100%" />
                                    </div>

                                    <div class="config-row">
                                        <label>Size</label>
                                        <TelerikDropDownList Data="@TickSizeOptions"
                                                             @bind-Value="XAxisConfig.MajorTickSize"
                                                             Width="100%" />
                                    </div>

                                    <div class="config-row">
                                        <label>Color</label>
                                        <input type="color"
                                               value="@XAxisConfig.MajorTickColor"
                                               @onchange="@((ChangeEventArgs e) => XAxisConfig.MajorTickColor = e.Value?.ToString() ?? "#000")"
                                               class="custom-color-input" />
                                    </div>

                                    <div class="config-row inline">
                                        <label>Grid Lines</label>
                                        <TelerikSwitch @bind-Value="XAxisConfig.ShowMajorGridLines" />
                                    </div>

                                    @if (XAxisConfig.ShowMajorGridLines)
                                    {
                                        <div class="config-row">
                                            <label>Grid Dash</label>
                                            <TelerikDropDownList Data="@DashTypes"
                                                                 TextField="Text"
                                                                 ValueField="Value"
                                                                 Value="@XAxisConfig.MajorGridDash"
                                                                 ValueChanged="@((string v) => XAxisConfig.MajorGridDash = v)"
                                                                 Width="100%" />
                                        </div>

                                        <div class="config-row">
                                            <label>Grid Width</label>
                                            <TelerikDropDownList Data="@GridWidthOptions"
                                                                 @bind-Value="XAxisConfig.MajorGridWidth"
                                                                 Width="100%" />
                                        </div>

                                        <div class="config-row">
                                            <label>Grid Color</label>
                                            <input type="color"
                                                   value="@XAxisConfig.MajorGridColor"
                                                   @onchange="@((ChangeEventArgs e) => XAxisConfig.MajorGridColor = e.Value?.ToString() ?? "#ddd")"
                                                   class="custom-color-input" />
                                        </div>
                                    }
                                }
                            </div>

                            <!-- Minor Ticks -->
                            <div class="tick-group">
                                <div class="config-row inline">
                                    <label><strong>Minor Ticks</strong></label>
                                    <TelerikSwitch @bind-Value="ShowMinorTicks" />
                                </div>

                                @if (ShowMinorTicks)
                                {
                                    <div class="config-row">
                                        <label>Step</label>
                                        <TelerikNumericTextBox @bind-Value="MinorTickStep"
                                                               Min="1" Max="100" Step="1"
                                                               Width="100%" />
                                    </div>

                                    <div class="config-row">
                                        <label>Size</label>
                                        <TelerikDropDownList Data="@TickSizeOptions"
                                                             @bind-Value="XAxisConfig.MinorTickSize"
                                                             Width="100%" />
                                    </div>

                                    <div class="config-row">
                                        <label>Color</label>
                                        <input type="color"
                                               value="@XAxisConfig.MinorTickColor"
                                               @onchange="@((ChangeEventArgs e) => XAxisConfig.MinorTickColor = e.Value?.ToString() ?? "#888")"
                                               class="custom-color-input" />
                                    </div>

                                    <div class="config-row inline">
                                        <label>Grid Lines</label>
                                        <TelerikSwitch @bind-Value="XAxisConfig.ShowMinorGridLines" />
                                    </div>

                                    @if (XAxisConfig.ShowMinorGridLines)
                                    {
                                        <div class="config-row">
                                            <label>Grid Dash</label>
                                            <TelerikDropDownList Data="@DashTypes"
                                                                 TextField="Text"
                                                                 ValueField="Value"
                                                                 Value="@XAxisConfig.MinorGridDash"
                                                                 ValueChanged="@((string v) => XAxisConfig.MinorGridDash = v)"
                                                                 Width="100%" />
                                        </div>

                                        <div class="config-row">
                                            <label>Grid Width</label>
                                            <TelerikDropDownList Data="@GridWidthOptions"
                                                                 @bind-Value="XAxisConfig.MinorGridWidth"
                                                                 Width="100%" />
                                        </div>

                                        <div class="config-row">
                                            <label>Grid Color</label>
                                            <input type="color"
                                                   value="@XAxisConfig.MinorGridColor"
                                                   @onchange="@((ChangeEventArgs e) => XAxisConfig.MinorGridColor = e.Value?.ToString() ?? "#ddd")"
                                                   class="custom-color-input" />
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </TabStripTab>

                    <!-- ===== TAB 4: Y AXIS ===== -->
                    <TabStripTab Title="Y Axis">
                        <div class="config-section">

                            <div class="config-row inline">
                                <label>Sync Min/Max across all Y axes</label>
                                <TelerikSwitch @bind-Value="SyncYAxisMinMax" />
                            </div>

                            @if (SyncYAxisMinMax)
                            {
                                <div class="config-row">
                                    <label>Global Min Value (empty=auto)</label>
                                    <TelerikNumericTextBox @bind-Value="GlobalYAxisMin"
                                                           Width="100%"
                                                           Format="N2" />
                                </div>

                                <div class="config-row">
                                    <label>Global Max Value (empty=auto)</label>
                                    <TelerikNumericTextBox @bind-Value="GlobalYAxisMax"
                                                           Width="100%"
                                                           Format="N2" />
                                </div>

                                <div class="config-row" style="display:flex; gap:8px; align-items:center;">
                                    <TelerikButton OnClick="@AutoSetGlobalYRange"
                                                   Size="sm"
                                                   Icon="@SvgIcon.ArrowRotateCcw">
                                        Auto set from data
                                    </TelerikButton>

                                    <small class="text-muted">Uses currently visible (aggregated) points.</small>
                                </div>
                            }

                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.ArrowsTopBottom" /> Y Axes
                                <div style="margin-left:auto;">
                                    <TelerikButton Size="sm" OnClick="@AddYAxis" Icon="@SvgIcon.Plus">
                                        Add Axis
                                    </TelerikButton>
                                </div>
                            </div>

                            @if (!YAxisConfigs.Any())
                            {
                                <div class="empty-state">
                                    <p>No Y axes defined. Add one to map tags to axes.</p>
                                </div>
                            }

                            @foreach (var axisId in GetDistinctYAxes())
                            {
                                var yConfig = GetYAxisConfig(axisId);

                                var mapped = SeriesConfigs
                                .Where(kv => kv.Value.AxisName == axisId)
                                .Select(kv => kv.Key)
                                .ToList();

                                <div class="axis-config-block">
                                    <div class="section-title clickable"
                                         @onclick="@(() => yConfig.IsExpanded = !yConfig.IsExpanded)">
                                        <TelerikSvgIcon Icon="@SvgIcon.ArrowsTopBottom" />
                                        Y Axis: @axisId

                                        <div style="margin-left:auto; display:flex; gap:6px; align-items:center;">
                                            <span @onclick:stopPropagation="true">
                                                <TelerikButton FillMode="flat"
                                                               Size="sm"
                                                               Icon="@SvgIcon.ArrowUp"
                                                               OnClick="@(() => MoveYAxisUp(axisId))"
                                                               Enabled="@(GetDistinctYAxes().IndexOf(axisId) > 0)" />
                                            </span>

                                            <span @onclick:stopPropagation="true">
                                                <TelerikButton FillMode="flat"
                                                               Size="sm"
                                                               Icon="@SvgIcon.ArrowDown"
                                                               OnClick="@(() => MoveYAxisDown(axisId))"
                                                               Enabled="@(GetDistinctYAxes().IndexOf(axisId) < GetDistinctYAxes().Count - 1)" />
                                            </span>

                                            <TelerikSvgIcon Icon="@(yConfig.IsExpanded? SvgIcon.ChevronUp: SvgIcon.ChevronDown)" />
                                        </div>
                                    </div>

                                    @* Show mapped series for this axis *@
                                    @if (mapped.Any())
                                    {
                                        <div class="mapped-series-list" style="padding:8px 10px;">
                                            <strong>Mapped series:</strong>
                                            @foreach (var t in mapped)
                                            {
                                                var display = !string.IsNullOrEmpty(SeriesConfigs[t].Name) ? SeriesConfigs[t].Name : t;
                                                <span class="mapped-series-item">@display</span>
                                            }
                                        </div>
                                    }

                                    @if (yConfig.IsExpanded)
                                    {
                                        <div class="config-row inline">
                                            <label>Visible</label>
                                            <TelerikSwitch Value="@yConfig.Visible"
                                                           ValueChanged="@((bool v) => SetYAxisVisible(axisId, v))" />

                                        </div>

                                        <div class="config-row">
                                            <label>Title</label>
                                            <TelerikTextBox @bind-Value="yConfig.Title"
                                                            Placeholder="@axisId"
                                                            Width="100%" />
                                        </div>

                                        <div class="config-row">
                                            <label>Position</label>
                                            <TelerikDropDownList Data="@(new List<string> { "Left", "Right" })"
                                                                 Value="@yConfig.Position"
                                                                 ValueChanged="@((string v) => SetYAxisPosition(axisId, v))"
                                                                 Width="100%" />
                                        </div>

                                        <div class="config-row">
                                            <label>Min Value (empty=auto)</label>
                                            <TelerikNumericTextBox @bind-Value="yConfig.Min"
                                                                   Width="100%"
                                                                   Format="N2" />
                                        </div>

                                        <div class="config-row">
                                            <label>Max Value (empty=auto)</label>
                                            <TelerikNumericTextBox @bind-Value="yConfig.Max"
                                                                   Width="100%"
                                                                   Format="N2" />
                                        </div>

                                        <div class="config-row">
                                            <label>Axis Color</label>
                                            <input type="color"
                                                   value="@yConfig.AxisColor"
                                                   @onchange="@((ChangeEventArgs e) => yConfig.AxisColor = e.Value?.ToString() ?? "#000")"
                                                   class="custom-color-input" />
                                        </div>

                                        <!-- Y Major Ticks -->
                                        <div class="tick-group">
                                            <div class="config-row inline">
                                                <label><strong>Major Ticks</strong></label>
                                                <TelerikSwitch @bind-Value="yConfig.ShowMajorTicks" />
                                            </div>

                                            @if (yConfig.ShowMajorTicks)
                                            {
                                                <div class="config-row">
                                                    <label>Major Unit</label>
                                                    <TelerikNumericTextBox @bind-Value="yConfig.MajorUnit"
                                                                           Min="1.0" Max="10000.0" Step="10.0"
                                                                           Width="100%" Format="N0" />
                                                </div>

                                                <div class="config-row inline">
                                                    <label>Grid Lines</label>
                                                    <TelerikSwitch @bind-Value="yConfig.ShowMajorGridLines" />
                                                </div>

                                                @if (yConfig.ShowMajorGridLines)
                                                {
                                                    <div class="config-row">
                                                        <label>Grid Dash</label>
                                                        <TelerikDropDownList Data="@DashTypes"
                                                                             TextField="Text"
                                                                             ValueField="Value"
                                                                             Value="@yConfig.MajorGridDash"
                                                                             ValueChanged="@((string v) => yConfig.MajorGridDash = v)"
                                                                             Width="100%" />
                                                    </div>

                                                    <div class="config-row">
                                                        <label>Grid Color</label>
                                                        <input type="color"
                                                               value="@yConfig.MajorGridColor"
                                                               @onchange="@((ChangeEventArgs e) => yConfig.MajorGridColor = e.Value?.ToString() ?? "#ddd")"
                                                               class="custom-color-input" />
                                                    </div>
                                                }
                                            }
                                        </div>

                                        <!-- Y Minor Ticks -->
                                        <div class="tick-group">
                                            <div class="config-row inline">
                                                <label><strong>Minor Ticks</strong></label>
                                                <TelerikSwitch @bind-Value="yConfig.ShowMinorTicks" />
                                            </div>

                                            @if (yConfig.ShowMinorTicks)
                                            {
                                                <div class="config-row">
                                                    <label>Minor Unit</label>
                                                    <TelerikNumericTextBox @bind-Value="yConfig.MinorUnit"
                                                                           Min="1.0" Max="5000.0" Step="5.0"
                                                                           Width="100%" Format="N0" />
                                                </div>
                                            }
                                        </div>


                                        <div style="margin-top:8px;">
                                            <TelerikButton ThemeColor="ThemeColor.Error" Size="sm"
                                                           OnClick="@( () => RemoveYAxis(axisId))"
                                                           Icon="@SvgIcon.Trash">
                                                Remove Axis
                                            </TelerikButton>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </TabStripTab>

                    <!-- ===== TAB 5: TOOLBAR ===== -->
                    <TabStripTab Title="Toolbar">
                        <div class="config-section">
                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.EditTools" /> Toolbar Settings
                            </div>

                            <div class="config-row inline">
                                <label>Show Toolbar</label>
                                <TelerikSwitch @bind-Value="ShowToolbar" />
                            </div>

                            <div class="config-row inline">
                                <label>Show Pause/Resume Button</label>
                                <TelerikSwitch @bind-Value="ShowPauseResumeButton" Enabled="ShowToolbar" />
                            </div>

                            <div class="config-row inline">
                                <label>Show ShowAll Button</label>
                                <TelerikSwitch @bind-Value="ShowShowAllButton" Enabled="ShowToolbar" />
                            </div>

                            <div class="config-row inline">
                                <label>Show HideAll Button</label>
                                <TelerikSwitch @bind-Value="ShowHideAllButton" Enabled="ShowToolbar" />
                            </div>
                        </div>
                    </TabStripTab>

                    <!-- ===== TAB 6: LEGEND ===== -->
                    <TabStripTab Title="Legend">
                        <div class="config-section">
                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.ListUnordered" /> Legend Settings
                            </div>

                            <div class="config-row inline">
                                <label>Show Legend</label>
                                <TelerikSwitch @bind-Value="ShowLegend" />
                            </div>

                            <div class="config-row">
                                <label>Position</label>
                                <div class="position-buttons">
                                    @foreach (var pos in LegendPositions)
                                    {
                                        <TelerikButton ThemeColor="@(SelectedLegendPosition == pos ? ThemeColor.Primary : ThemeColor.Base)"
                                                       Size="sm"
                                                       OnClick="@(() => SelectedLegendPosition = pos)">
                                            @pos
                                        </TelerikButton>
                                    }
                                </div>
                            </div>

                            <hr />

                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.Shapes" /> Legend Marker
                            </div>

                            <div class="config-row inline">
                                <label>Visible</label>
                                <TelerikSwitch @bind-Value="LegendMarkerVisible" />
                            </div>

                            @if (LegendMarkerVisible)
                            {
                                <div class="config-row">
                                    <label>Marker Shape</label>
                                    <TelerikDropDownList Data="@MarkerTypes"
                                                         TextField="Text"
                                                         ValueField="Value"
                                                         @bind-Value="LegendMarkerType"
                                                         Enabled="LegendMarkerVisible"
                                                         Width="100%" />
                                </div>

                                <div class="config-row">
                                    <label>Marker Color</label>
                                    <input type="color"
                                           value="@LegendMarkerBackground"
                                           @onchange="@((ChangeEventArgs e) => LegendMarkerBackground = e.Value?.ToString() ?? "")"
                                           class="custom-color-input" />
                                </div>

                                <div class="config-row">
                                    <label>Border Color</label>
                                    <input type="color"
                                           value="@LegendMarkerBorderColor"
                                           @onchange="@((ChangeEventArgs e) => LegendMarkerBorderColor = e.Value?.ToString() ?? "#666")"
                                           class="custom-color-input" />
                                </div>

                                <hr />

                                <div class="section-title">
                                    <TelerikSvgIcon Icon="@SvgIcon.Pointer" /> Highlight Marker (hover)
                                </div>

                                <div class="config-row">
                                    <label>Highlight Background</label>
                                    <input type="color"
                                           value="@LegendMarkerHighlightBackground"
                                           @onchange="@((ChangeEventArgs e) => LegendMarkerHighlightBackground = e.Value?.ToString() ?? "#ffeb3b")"
                                           class="custom-color-input" />
                                </div>

                                <div class="config-row">
                                    <label>Highlight Border Color</label>
                                    <input type="color"
                                           value="@LegendMarkerHighlightBorderColor"
                                           @onchange="@((ChangeEventArgs e) => LegendMarkerHighlightBorderColor = e.Value?.ToString() ?? "#999")"
                                           class="custom-color-input" />
                                </div>
                            }
                        </div>
                    </TabStripTab>

                    <!-- ===== TAB 7: TOOLTIP ===== -->
                    <TabStripTab Title="ToolTip">
                        <div class="config-section">
                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.Comment" /> Tooltip
                            </div>

                            <div class="config-row inline">
                                <label>Show Tooltip</label>
                                <TelerikSwitch @bind-Value="ShowTooltip" />
                            </div>

                            <div class="config-row inline">
                                <label>Shared Tooltip</label>
                                <TelerikSwitch @bind-Value="SharedTooltip" Enabled="ShowTooltip" />
                            </div>

                            <div class="config-row">
                                <label>Shared Tooltip Background</label>
                                <input type="color"
                                       value="@TooltipBackground"
                                       @onchange="@((ChangeEventArgs e) => TooltipBackground = e.Value?.ToString() ?? "#ffffff")"
                                       class="custom-color-input" />
                            </div>
                        </div>
                    </TabStripTab>

                    <!-- ===== TAB 8: DISPLAY ===== -->
                    <TabStripTab Title="Display">
                        <div class="config-section">

                            <!-- Chart Appearance -->
                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.Image" /> Appearance
                            </div>

                            <div class="config-row">
                                <label>Chart Title</label>
                                <TelerikTextBox @bind-Value="CustomChartTitle"
                                                Placeholder="Auto-generated"
                                                Width="100%" />
                            </div>

                            <div class="config-row">
                                <label>Title Alignment</label>
                                <TelerikDropDownList Data="@TitleAlignOptions"
                                                     @bind-Value="TitleAlignment"
                                                     Width="100%" />
                            </div>

                            <div class="config-row">
                                <label>Chart Height</label>
                                <TelerikDropDownList Data="@ChartHeightOptions"
                                                     @bind-Value="ChartHeight"
                                                     Width="100%" />

                            </div>

                            <div class="config-row">
                                <label>Background</label>
                                <div class="theme-buttons">
                                    <TelerikButton ThemeColor="@(ChartBackground == "white" ? ThemeColor.Primary : ThemeColor.Base)"
                                                   Size="sm"
                                                   OnClick="@(() => ChartBackground = "white")">
                                        Light
                                    </TelerikButton>
                                    <TelerikButton ThemeColor="@(ChartBackground == "#1e1e2f" ? ThemeColor.Primary : ThemeColor.Base)"
                                                   Size="sm"
                                                   OnClick="@(() => ChartBackground = "#1e1e2f")">
                                        Dark
                                    </TelerikButton>
                                    <input type="color"
                                           value="@ChartBackground"
                                           @onchange="@((ChangeEventArgs e) => ChartBackground = e.Value?.ToString() ?? "white")"
                                           class="custom-color-input" />
                                </div>
                            </div>

                            <div class="config-row">
                                <label>Rendering</label>
                                <TelerikDropDownList Data="@RenderModes"
                                                     TextField="Text"
                                                     ValueField="Value"
                                                     @bind-Value="SelectedRenderMode"
                                                     Width="100%" />
                            </div>

                            <div class="config-row inline">
                                <label>Transitions / Animation</label>
                                <TelerikSwitch @bind-Value="EnableTransitions" />
                            </div>

                            <hr />

                            <!-- Layout controls -->
                            <div class="section-title">
                                <TelerikSvgIcon Icon="@SvgIcon.Layout" /> Layout & Spacing
                            </div>

                            <div class="config-row">
                                <label>Chart Margin (T R B L)</label>
                                <div class="d-flex gap-2">
                                    <TelerikNumericTextBox @bind-Value="ChartMarginTop" Min="0" Max="200" Width="25%" />
                                    <TelerikNumericTextBox @bind-Value="ChartMarginRight" Min="0" Max="200" Width="25%" />
                                    <TelerikNumericTextBox @bind-Value="ChartMarginBottom" Min="0" Max="200" Width="25%" />
                                    <TelerikNumericTextBox @bind-Value="ChartMarginLeft" Min="0" Max="200" Width="25%" />
                                </div>
                                <small class="text-muted">Top Right Bottom Left (px)</small>
                            </div>

                            <div class="config-row">
                                <label>Plot Area Padding</label>
                                <TelerikNumericTextBox @bind-Value="PlotAreaPadding" Min="0" Max="100" Width="100%" />
                            </div>

                            <hr />

                            <div class="config-row" style="margin-top:8px;">
                                <TelerikButton OnClick="@ResetToDefaults"
                                               ThemeColor="ThemeColor.Error"
                                               Icon="@SvgIcon.ArrowRotateCcw"
                                               Class="full-width-btn">
                                    Reset to Defaults
                                </TelerikButton>
                            </div>
                        </div>
                    </TabStripTab>

                </TelerikTabStrip>
            </div>

            <!-- Show Trend Button -->
            <div class="sidebar-footer">
                <TelerikButton OnClick="@OpenChart"
                               ThemeColor="ThemeColor.Primary"
                               Size="lg"
                               Class="full-width-btn"
                               Icon="@SvgIcon.ChartLineStacked">
                    Show Trend Chart
                </TelerikButton>
            </div>
        }
    </div>

    <!-- ================= CHART WINDOW ================= -->
    <TelerikWindow @bind-Visible="ShowWindow"
                   Width="1400px"
                   Height="800px"
                   Modal="false"
                   Draggable="true"
                   Resizable="true">

        <WindowTitle>
            <div class="window-title-bar">
                <span>📊 Live Trend Chart</span>
            </div>
        </WindowTitle>

        <WindowActions>
            <WindowAction Name="Close"
                          OnClick="@(() => ShowWindow = false)" />
        </WindowActions>

        <WindowContent>

            <div class="mb-2 d-flex gap-2 align-items-center flex-wrap">
                @if (ShowToolbar)
                {
                    @if (ShowPauseResumeButton)
                    {
                        <TelerikButton OnClick="@TogglePauseResume"
                                       ThemeColor="@(IsPaused ? ThemeColor.Success : ThemeColor.Warning)"
                                       Icon="@(IsPaused ? SvgIcon.Play : SvgIcon.Pause)">
                            @(IsPaused ? "Resume" : "Pause")
                        </TelerikButton>
                    }

                    @if (ShowShowAllButton)
                    {
                        <TelerikButton OnClick="@ShowAllSeries" ThemeColor="ThemeColor.Info">
                            Show All Series
                        </TelerikButton>
                    }

                    @if (ShowHideAllButton)
                    {
                        <TelerikButton OnClick="@HideAllSeries" ThemeColor="ThemeColor.Error">
                            Hide All Series
                        </TelerikButton>
                    }
                }

                @* ── Status badges ── *@
                @if (IsLiveMode && !IsPaused)
                {
                    <span class="badge bg-success ms-2" style="font-size: 0.85rem;">
                        ● Live
                    </span>
                }
                else if (IsPaused && PausedByInteraction)
                {
                    <span class="badge bg-warning text-dark ms-2" style="font-size: 0.85rem;">
                        ⚠ Auto-paused (zoom/pan detected)
                    </span>
                }
                else if (IsPaused)
                {
                    <span class="badge bg-secondary ms-2" style="font-size: 0.85rem;">
                        ⏸ Manually paused
                    </span>
                }
                else
                {
                    <span class="badge bg-info text-dark ms-2" style="font-size: 0.85rem;">
                        📜 Viewing history
                    </span>
                }

                @* ── Window position info ── *@
                @if (VisibleMin.HasValue && VisibleMax.HasValue)
                {
                    <span class="badge bg-light text-dark ms-2 border" style="font-size: 0.8rem;">
                        🕐 @VisibleMin.Value.ToString(GetTooltipTimeFormat())
                        → @VisibleMax.Value.ToString(GetTooltipTimeFormat())
                    </span>
                }

                <span class="badge bg-light text-dark ms-2 border" style="font-size: 0.8rem;">
                    📊 @ChartData.Count points in memory
                </span>
            </div>

            <!-- Chart Wrapper -->
            <div id="chartInteractionWrapper"
                 @onmousedown="OnChartMouseDown"
                 @onmousemove="OnChartMouseMove"
                 @onmouseup="OnChartMouseUp"
                 @onmouseleave="OnChartMouseLeave"
                 @onwheel="OnChartWheel"
                 @onwheel:preventDefault="@_preventWheelDefault"
                 style="border-radius: 8px; padding:@($"{PlotAreaPadding}px"); margin:@($"{ChartMarginTop}px {ChartMarginRight}px {ChartMarginBottom}px {ChartMarginLeft}px");">

                <TelerikChart @key="_chartKey"
                              Height="@($"{ChartHeight}px")"
                              Transitions="@EnableTransitions"
                              RenderAs="@GetRenderMode()"
                              OnLegendItemClick="@OnLegendItemClick">

                    <ChartPlotArea Background="@ChartBackground" Opacity="@(ChartPlotAreaOpacity)">
                        <ChartPlotAreaBorder Color="#e6e6e6" Width="1" />
                    </ChartPlotArea>

                    <ChartTitle Text="@CustomChartTitle" Align="@GetChartTitleAlign()" />

                    <ChartLegend Visible="@ShowLegend"
                                 Position="@GetLegendPosition()">
                        @if (LegendMarkerVisible)
                        {
                            <ChartLegendItem>
                                <ChartLegendItemMarkers Background="@LegendMarkerBackground"
                                                        Type="@GetMarkerType(LegendMarkerType)"
                                                        Visible="@LegendMarkerVisible">
                                    <ChartLegendItemMarkersBorder Color="@LegendMarkerBorderColor" />
                                </ChartLegendItemMarkers>

                                <ChartLegendItemHighlight>
                                    <ChartLegendItemHighlightMarkers Background="@LegendMarkerHighlightBackground"
                                                                     Visible="true">
                                        <ChartLegendItemHighlightMarkersBorder Color="@LegendMarkerHighlightBorderColor" />
                                    </ChartLegendItemHighlightMarkers>
                                </ChartLegendItemHighlight>

                            </ChartLegendItem>
                        }
                    </ChartLegend>

                    <ChartZoomable Enabled="true">
                        <ChartZoomableMousewheel Enabled="false" />
                    </ChartZoomable>

                    <ChartPannable Enabled="true" />

                    <ChartTooltip Visible="@ShowTooltip"
                                  Shared="@SharedTooltip"
                                  Background="@(SharedTooltip ? TooltipBackground : null)">
                        <SharedTemplate Context="context">
                            @{
                                string categoryText = "";
                                var firstPoint = context.Points.FirstOrDefault();

                                if (firstPoint?.DataItem is AggregatedReading firstDataItem)
                                {
                                    categoryText = firstDataItem.Time.ToString(GetTooltipTimeFormat());
                                }
                                else
                                {
                                    categoryText = context.Category?.ToString() ?? "";
                                }
                            }

                            <div>
                                Time: <strong>@categoryText</strong>
                                <hr style="margin:5px 0;" />

                                @foreach (var point in context.Points)
                                {
                                    var seriesName = point.SeriesName ?? "";

                                    object rawValue = null;

                                    var pointType = point.GetType();
                                    var pointValueProp = pointType.GetProperty("Value");
                                    if (pointValueProp != null)
                                    {
                                        rawValue = pointValueProp.GetValue(point);
                                    }
                                    else if (point.DataItem != null)
                                    {
                                        var pointData = point.DataItem;
                                        var prop = pointData.GetType().GetProperty("Value")
                                        ?? pointData.GetType().GetProperty("value");
                                        if (prop != null)
                                        {
                                            rawValue = prop.GetValue(pointData);
                                        }
                                        else
                                        {
                                            // If DataItem is a primitive numeric type
                                            if (pointData is double || pointData is float || pointData is decimal
                                            || pointData is int || pointData is long)
                                            {
                                                rawValue = pointData;
                                            }
                                        }
                                    }

                                    if (rawValue != null)
                                    {
                                        if (double.TryParse(rawValue.ToString(), out var number))
                                        {
                                            <div>
                                                @seriesName:
                                                <strong>@number.ToString("N2")</strong>
                                            </div>
                                        }
                                        else
                                        {
                                            <div>
                                                @seriesName:
                                                <strong>@rawValue</strong>
                                            </div>
                                        }
                                    }
                                }
                            </div>
                        </SharedTemplate>

                        <Template Context="context">
                            @{
                                string tipTime = "";

                                if (context.DataItem is AggregatedReading tipItem)
                                {
                                    tipTime = tipItem.Time.ToString(GetTooltipTimeFormat());
                                }

                                var tipProp = context.DataItem?.GetType()
                                .GetProperty("Value");
                                var tipValue = tipProp?.GetValue(context.DataItem);
                                double tipNumber = 0;
                                bool hasTipNumber = tipValue != null
                                && double.TryParse(tipValue.ToString(), out tipNumber);

                                var seriesColor = GetSeriesColor(context.SeriesName);
                                var textColor = GetContrastingTextColor(seriesColor);
                            }

                            <div style="background:@seriesColor; color:@textColor; padding:10px; border-radius:6px; max-width:320px;">
                                <strong>@context.SeriesName</strong><br />
                                Time: @tipTime<br />
                                Value: <strong>@(hasTipNumber? tipNumber.ToString("N2") : tipValue?.ToString())</strong>
                            </div>
                        </Template>

                    </ChartTooltip>

                    <!-- Category Axis -->
                    <ChartCategoryAxes>
                        <ChartCategoryAxis Type="ChartCategoryAxisType.Date"
                                           BaseUnit="@GetBaseUnit()"
                                           BaseUnitStep="@GetAutoBaseUnitStep()"
                                           Min="@VisibleMin"
                                           Max="@VisibleMax"
                                           AxisCrossingValue="@GetCategoryAxisCrossings()"
                                           Visible="@XAxisConfig.Visible"
                                           Color="@XAxisConfig.AxisColor">

                            <ChartCategoryAxisMajorTicks Visible="@ShowMajorTicks"
                                                         Size="@XAxisConfig.MajorTickSize"
                                                         Color="@XAxisConfig.MajorTickColor"
                                                         Step="@MajorTickStep" />

                            <ChartCategoryAxisMinorTicks Visible="@ShowMinorTicks"
                                                         Size="@XAxisConfig.MinorTickSize"
                                                         Color="@XAxisConfig.MinorTickColor"
                                                         Step="@MinorTickStep" />

                            <ChartCategoryAxisMajorGridLines Visible="@(ShowMajorTicks && XAxisConfig.ShowMajorGridLines)"
                                                             Width="@XAxisConfig.MajorGridWidth"
                                                             Step="@MajorTickStep"
                                                             Color="@XAxisConfig.MajorGridColor"
                                                             DashType="@GetDashType(XAxisConfig.MajorGridDash)" />

                            <ChartCategoryAxisMinorGridLines Visible="@(ShowMinorTicks && XAxisConfig.ShowMinorGridLines)"
                                                             Width="@XAxisConfig.MinorGridWidth"
                                                             Step="@MinorTickStep"
                                                             Color="@XAxisConfig.MinorGridColor"
                                                             DashType="@GetDashType(XAxisConfig.MinorGridDash)" />

                            <ChartCategoryAxisTitle Text="@(string.IsNullOrEmpty(XAxisConfig.Title) ? GetXAxisTitle() : XAxisConfig.Title)" />

                            <ChartCategoryAxisLabels Format="@GetAxisLabelFormat()"
                                                     Step="@(ShowMajorTicks ? MajorTickStep : 1)">
                                <ChartCategoryAxisLabelsRotation Angle="@CategoryLabelRotation"
                                                                 Align="ChartAxisLabelsRotationAlignment.Center" />
                            </ChartCategoryAxisLabels>

                        </ChartCategoryAxis>
                    </ChartCategoryAxes>

                    <!-- Value Axes -->
                    <ChartValueAxes>
                        @foreach (var axisId in GetDistinctYAxes())
                        {
                            var yConfig = GetYAxisConfig(axisId);
                            <ChartValueAxis Name="@axisId"
                                            AxisCrossingValue="@(new object[] { double.MinValue })"
                                            Visible="@yConfig.Visible"
                                            Color="@yConfig.AxisColor"
                                            Min="@(SyncYAxisMinMax ? GlobalYAxisMin : (yConfig.Min ?? (AxisHasNegativeValues(axisId) ? (double?)null : 0.0)))"
                                            Max="@(SyncYAxisMinMax ? GlobalYAxisMax : yConfig.Max)"
                                            MajorUnit="@(yConfig.ShowMajorTicks ? yConfig.MajorUnit : (double?)null)"
                                            MinorUnit="@(yConfig.ShowMinorTicks ? yConfig.MinorUnit : (double?)null)">

                                <ChartValueAxisTitle Text="@(string.IsNullOrEmpty(yConfig.Title) ? axisId : yConfig.Title)" />

                                <ChartValueAxisMajorTicks Visible="@yConfig.ShowMajorTicks"
                                                          Size="6"
                                                          Color="@yConfig.AxisColor" />

                                <ChartValueAxisMinorTicks Visible="@yConfig.ShowMinorTicks"
                                                          Size="3" />

                                <ChartValueAxisMajorGridLines Visible="@(yConfig.ShowMajorTicks && yConfig.ShowMajorGridLines)"
                                                              Width="1"
                                                              Color="@yConfig.MajorGridColor"
                                                              DashType="@GetDashType(yConfig.MajorGridDash)" />

                                <ChartValueAxisMinorGridLines Visible="@(yConfig.ShowMinorTicks)"
                                                              Width="0.5"
                                                              DashType="DashType.Dot" />

                                @if (PlotBands.Any(p => p.AxisName == axisId))
                                {
                                    <ChartValueAxisPlotBands>
                                        @foreach (var band in PlotBands.Where(p => p.AxisName == axisId))
                                        {
                                            <ChartValueAxisPlotBand From="@band.From"
                                                                    To="@band.To"
                                                                    Color="@band.Color"
                                                                    Opacity="@((float)band.Opacity)" />
                                        }
                                    </ChartValueAxisPlotBands>
                                }
                            </ChartValueAxis>
                        }
                    </ChartValueAxes>

                    <!-- Series -->
                    <ChartSeriesItems>
                        @foreach (var tag in SelectedTags)
                        {
                            var cfg = GetSeriesConfig(tag);
                            var axisName = cfg.AxisName ?? GetDistinctYAxes().FirstOrDefault() ?? "Axis 1";

                            if (!GetYAxisConfig(axisName).Visible)
                            {
                                continue;
                            }

                            var isHidden = cfg.IsHidden || HiddenSeries.Contains(tag);
                            var displayName = !string.IsNullOrEmpty(cfg.Name) ? cfg.Name : tag;

                            <ChartSeries Data="@GetSeriesData(tag)"
                                         Field="Value"
                                         CategoryField="Time"
                                         Type="@GetSeriesType(cfg.ChartType)"
                                         Name="@displayName"
                                         Axis="@axisName"
                                         Color="@cfg.Color"
                                         Visible="@(!isHidden)"
                                         Style="@(cfg.IsSmooth ? ChartSeriesStyle.Smooth : ChartSeriesStyle.Normal)"
                                         DashType="@GetDashType(cfg.LineStyle)"
                                         Width="@cfg.LineWidth"
                                         Gap="@cfg.BarGap"
                                         Opacity="@((float)(cfg.ChartType == "Area" ? cfg.AreaOpacity : 1.0))">

                                <ChartSeriesLine Style="@(cfg.IsSmooth? ChartSeriesLineStyle.Smooth: ChartSeriesLineStyle.Normal)" />

                                <ChartSeriesStack Enabled="@(IsStacked && IsStackSupported(cfg.ChartType))"
                                                  Type="@GetStackType()" />

                                <ChartSeriesMarkers Visible="@(cfg.ShowMarkers)"
                                                    Type="@GetMarkerType(cfg.MarkerType)"
                                                    Size="@cfg.MarkerSize" />

                                <ChartSeriesBorder Width="@cfg.BorderWidth"
                                                   Color="@cfg.BorderColor" />

                                @if (cfg.ShowDataLabels)
                                {
                                    <ChartSeriesLabels Visible="true"
                                                       Format="@cfg.DataLabelFormat"
                                                       Position="@GetLabelPosition(cfg.DataLabelPosition)" />
                                }
                            </ChartSeries>

                            @* Trendline per series *@
                            @if (cfg.ShowTrendline)
                            {
                                var trendDisplayName = $"{displayName} Trend";
                                var trendKey = $"{tag}_trend";
                                var isTrendHidden = HiddenSeries.Contains(trendKey);

                                <ChartSeries Data="@GetSeriesData(tag)"
                                             For="@tag"
                                             Type="@GetTrendlineSeriesType(cfg.TrendlineType)"
                                             Name="@trendDisplayName"
                                             Color="@cfg.TrendlineColor"
                                             Visible="@(!isTrendHidden)">
                                </ChartSeries>
                            }
                        }
                    </ChartSeriesItems>

                </TelerikChart>

            </div>
        </WindowContent>
    </TelerikWindow>

</div>

@code {

    // ═══════════════════════════════════════════════════════
    //  STATE
    // ═══════════════════════════════════════════════════════

    private bool ShowWindow = false;
    private bool ShowLegend = true;
    private bool IsPaused = false;
    private bool ShowTooltip = true;
    private bool SharedTooltip = true;
    private bool IsStacked = false;
    private bool PausedByInteraction = false;
    private bool _preventWheelDefault = false;
    private bool IsConfigCollapsed = false;
    private bool EnableTransitions = false;

    private int CategoryLabelRotation = -45;
    private string SelectedRange = "30s";
    private string SelectedStackType = "Normal";
    private string SelectedRenderMode = "Canvas";
    private string ChartBackground = "white";
    private double ChartPlotAreaOpacity = 1.0;
    private string CustomChartTitle = "";
    private string TooltipBackground = "#e6e6e6";
    private int ChartHeight = 550;
    private int ActiveConfigTab = 0;

    // Toolbar settings
    private bool ShowToolbar = true;
    private bool ShowPauseResumeButton = true;
    private bool ShowShowAllButton = false;
    private bool ShowHideAllButton = false;

    // Legend marker customization
    private string SelectedLegendPosition = "Bottom";
    private bool LegendMarkerVisible = false;
    private string LegendMarkerType = "Circle";
    private string LegendMarkerBackground = "#116fd4";
    private string LegendMarkerBorderColor = "#666666";
    private string LegendMarkerHighlightBackground = "#ffeb3b";
    private string LegendMarkerHighlightBorderColor = "#999999";

    // Layout-specific properties
    private int ChartMarginTop = 25;
    private int ChartMarginRight = 8;
    private int ChartMarginBottom = 8;
    private int ChartMarginLeft = 8;
    private int PlotAreaPadding = 8;
    private string TitleAlignment = "Center";
    private List<string> TitleAlignOptions = new() { "Left", "Center", "Right" };

    // Backing field + property so dropdown changes immediately update timer interval
    private int _refreshIntervalMs = 100;
    private int RefreshIntervalMs
    {
        get => _refreshIntervalMs;
        set
        {
            if (_refreshIntervalMs == value) return;
            _refreshIntervalMs = value;
            UpdateTimerInterval();
        }
    }

    private List<int> RefreshIntervalOptions = new() { 50, 100, 250, 500, 1000, 2000, 5000 };
    private List<int> ChartHeightOptions = new() { 400, 500, 550, 650, 750, 850 };
    private List<int> LineWidthOptions = Enumerable.Range(1, 8).ToList();
