    protected override async Task OnInitializedAsync()
    {
        await LoadDistinctTagsFromDb();
        // create a default axis so user can map tags immediately
        if (!YAxisConfigs.Any())
        {
            YAxisConfigs["Axis 1"] = new YAxisConfiguration { Name = "Axis 1", Title = "Axis 1" };
            if (!YAxisOrder.Contains("Axis 1")) YAxisOrder.Add("Axis 1");
        }

        await LoadDataForWindow(DateTime.Now);
        StartTimer();
    }

