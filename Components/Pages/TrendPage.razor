    private SeriesConfiguration GetSeriesConfig(string name)
    {
        if (!SeriesConfigs.ContainsKey(name))
        {
            var defaultAxis = YAxisConfigs.Keys.FirstOrDefault() ?? "Axis 1";
            SeriesConfigs[name] = new SeriesConfiguration
            {
                Name = name,
                Color = GetDefaultColor(SeriesConfigs.Count),
                ChartType = "Line",
                AxisName = defaultAxis
            };
        }
        return SeriesConfigs[name];
    }

    private void SetSeriesChartType(string name, string type)
    {
        GetSeriesConfig(name).ChartType = type;
        _chartKey++;
        StateHasChanged();
    }

    private void SetSeriesColor(string name, string color)
    {
        GetSeriesConfig(name).Color = color ?? "#116fd4";
        _chartKey++;
        StateHasChanged();
    }

    private void ToggleSeriesVisibility(string tag)
    {
        var cfg = GetSeriesConfig(tag);
        cfg.IsHidden = !cfg.IsHidden;

        if (cfg.IsHidden)
        {
            HiddenSeries.Add(tag);
            if (cfg.ShowTrendline)
                HiddenSeries.Add($"{tag}_trend");
        }
        else
        {
            HiddenSeries.Remove(tag);
            HiddenSeries.Remove($"{tag}_trend");
        }

        _chartKey++;
        StateHasChanged();
    }

    private void ToggleSeriesExpanded(string name)
    {
        var cfg = GetSeriesConfig(name);
        cfg.IsExpanded = !cfg.IsExpanded;
    }

    private void MoveSeriesUp(string name)
    {
        var idx = SelectedTags.IndexOf(name);
        if (idx <= 0) return;
        SelectedTags.RemoveAt(idx);
        SelectedTags.Insert(idx - 1, name);
        _chartKey++;
        StateHasChanged();
    }

    private void MoveSeriesDown(string name)
    {
        var idx = SelectedTags.IndexOf(name);
        if (idx < 0 || idx >= SelectedTags.Count - 1) return;
        SelectedTags.RemoveAt(idx);
        SelectedTags.Insert(idx + 1, name);
        _chartKey++;
        StateHasChanged();
    }

    private void SetSeriesAxis(string tag, string axisName)
    {
        var cfg = GetSeriesConfig(tag);
        cfg.AxisName = axisName ?? YAxisConfigs.Keys.FirstOrDefault() ?? "Axis 1";
        _chartKey++;
        StateHasChanged();
    }


    private void AddYAxisForSeries(string tag)
    {
        var newAxisName = GetNextAxisName();
        YAxisConfigs[newAxisName] = new YAxisConfiguration { Name = newAxisName, Title = newAxisName };
        if (!YAxisOrder.Contains(newAxisName)) YAxisOrder.Add(newAxisName);
        SetSeriesAxis(tag, newAxisName);
    }

    private string GetNextAxisName()
    {
        int i = 1;
        while (YAxisConfigs.ContainsKey($"Axis {i}")) i++;
        return $"Axis {i}";
    }

    private void SetYAxisPosition(string axisId, string position)
    {
        var pos = position ?? "Left";
        var yConfig = GetYAxisConfig(axisId);
        yConfig.Position = pos;
        _chartKey++;
        StateHasChanged();
    }

    private void SetYAxisVisible(string axisId, bool visible)
    {
        var yConfig = GetYAxisConfig(axisId);
        yConfig.Visible = visible;

        // When axis is hidden, optionally hide series mapped to it
        if (!visible)
        {
            var mapped = SeriesConfigs.Where(kv => kv.Value.AxisName == axisId);
            foreach (var kv in mapped)
            {
                kv.Value.IsHidden = true;
                HiddenSeries.Add(kv.Key);
                if (kv.Value.ShowTrendline)
                    HiddenSeries.Add($"{kv.Key}_trend");
            }
        }
        else
        {
            var mapped = SeriesConfigs.Where(kv => kv.Value.AxisName == axisId);
            foreach (var kv in mapped)
            {
                if (HiddenSeries.Contains(kv.Key))
                {
                    HiddenSeries.Remove(kv.Key);
                }
                if (HiddenSeries.Contains($"{kv.Key}_trend"))
                {
                    HiddenSeries.Remove($"{kv.Key}_trend");
                }

                kv.Value.IsHidden = false;
            }
        }

        _chartKey++;
        StateHasChanged();
    }

