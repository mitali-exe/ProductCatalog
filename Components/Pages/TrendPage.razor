    private List<string> GetDistinctYAxes()
    {
        var axes = new List<string>();

        // Start from explicit order if available
        if (YAxisOrder != null && YAxisOrder.Any())
        {
            foreach (var k in YAxisOrder)
            {
                if (!axes.Contains(k) && YAxisConfigs.ContainsKey(k))
                    axes.Add(k);
            }
        }
        else
        {
            foreach (var key in YAxisConfigs.Keys)
            {
                if (!axes.Contains(key))
                    axes.Add(key);
            }
        }

        // ensure axes referenced by series exist and append in deterministic order
        foreach (var s in SeriesConfigs.Values)
        {
            if (!string.IsNullOrEmpty(s.AxisName) && !axes.Contains(s.AxisName))
                axes.Add(s.AxisName);
        }

        // also ensure any YAxisConfigs keys not yet included are appended
        foreach (var key in YAxisConfigs.Keys)
        {
            if (!axes.Contains(key))
                axes.Add(key);
        }

        // Keep YAxisOrder in sync with final axes order
        YAxisOrder = axes.ToList();

        return axes;
    }

    private async Task OnSelectedTagsChanged(List<string> values)
    {
        var newSelection = values ?? new List<string>();

        var removed = SeriesConfigs.Keys.Except(newSelection).ToList();

        foreach (var key in removed)
        {
            SeriesConfigs.Remove(key);
            // remove any hidden entries that used the previous keys
            HiddenSeries.Remove(key);
            HiddenSeries.Remove($"{key}_trend");
            if (SeriesRenameBuffers.ContainsKey(key))
                SeriesRenameBuffers.Remove(key);
        }

        SelectedTags = newSelection;

        // ensure each selected tag has a configuration and default axis
        foreach (var tag in SelectedTags)
            _ = GetSeriesConfig(tag);

        _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    private YAxisConfiguration GetYAxisConfig(string axisId)
    {
        if (!YAxisConfigs.ContainsKey(axisId))
        {
            var cfg = new YAxisConfiguration
            {
                Name = axisId,
                Title = axisId
            };

            cfg.Position = "Left";

            YAxisConfigs[axisId] = cfg;
        }

        if (!YAxisOrder.Contains(axisId))
            YAxisOrder.Add(axisId);

        return YAxisConfigs[axisId];
    }

    private void AddYAxis()
    {
        var name = GetNextAxisName();
        YAxisConfigs[name] = new YAxisConfiguration { Name = name, Title = name };
        if (!YAxisOrder.Contains(name)) YAxisOrder.Add(name);
        _chartKey++;
        StateHasChanged();
    }

    private void RemoveYAxis(string axisId)
    {
        if (!YAxisConfigs.ContainsKey(axisId)) return;

        // remap any series using this axis to a default axis if possible
        var remaining = YAxisConfigs.Keys.Where(k => k != axisId).ToList();
        string fallback = remaining.FirstOrDefault() ?? null;

        foreach (var s in SeriesConfigs.Values.Where(s => s.AxisName == axisId))
        {
            s.AxisName = fallback;
        }

        YAxisConfigs.Remove(axisId);
        if (YAxisOrder.Contains(axisId)) YAxisOrder.Remove(axisId);

        _chartKey++;
        StateHasChanged();
    }

    private bool AxisHasNegativeValues(string axisId)
    {
        // Check selected tags mapped to this axis
        foreach (var tag in SelectedTags)
        {
            var cfg = SeriesConfigs.TryGetValue(tag, out var c) ? c : null;
            if (cfg == null) continue;
            if (cfg.AxisName != axisId) continue;

            var series = GetSeriesData(tag);
            if (series.Any(s => s.Value < 0.0))
            {
                return true;
            }
        }

        // No negative values found for mapped series
        return false;
    }

    // New: Move Y axis up/down in YAxisOrder
    private void MoveYAxisUp(string axisId)
    {
        var idx = YAxisOrder.IndexOf(axisId);
        if (idx > 0)
        {
            YAxisOrder.RemoveAt(idx);
            YAxisOrder.Insert(idx - 1, axisId);
            _chartKey++;
            StateHasChanged();
        }
    }

    private void MoveYAxisDown(string axisId)
    {
        var idx = YAxisOrder.IndexOf(axisId);
        if (idx >= 0 && idx < YAxisOrder.Count - 1)
        {
            YAxisOrder.RemoveAt(idx);
            YAxisOrder.Insert(idx + 1, axisId);
            _chartKey++;
            StateHasChanged();
        }
    }

