    private object[] GetCategoryAxisCrossings()
    {
        var axes = GetDistinctYAxes();
        var data = ChartData;
        int count = Math.Max(1, data.Count);
        var crossings = new List<object>();

        foreach (var axisId in axes)
        {
            var cfg = GetYAxisConfig(axisId);
            if (cfg.Position == "Right")
            {
                crossings.Add(count - 1);
            }
            else
            {
                crossings.Add(0);
            }
        }

        return crossings.ToArray();
    }


    // ═══════════════════════════════════════════════════════
    //  DATA LOADING
    // ═══════════════════════════════════════════════════════

    private async Task LoadDistinctTagsFromDb()
    {
        // Populate TagOptions with a new list reference so the MultiSelect sees the change immediately
        await using var db = await DbFactory.CreateDbContextAsync();

        var tags = await db.SensorReadings
            .Select(x => x.Tag)
            .Distinct()
            .OrderBy(t => t)
            .ToListAsync();

        TagOptions = tags.Select(t => new FieldOption { Text = t, Value = t }).ToList();

        // don't auto-select; leave it to user. but ensure default axis exists
        if (!YAxisConfigs.Any())
        {
            YAxisConfigs["Axis 1"] = new YAxisConfiguration { Name = "Axis 1", Title = "Axis 1" };
            if (!YAxisOrder.Contains("Axis 1")) YAxisOrder.Add("Axis 1");
        }

        // Force immediate UI update so the MultiSelect shows options without switching tabs
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDataForWindow(DateTime anchorMax)
    {
        int rangeSeconds = GetRangeSeconds();
        int bufferSeconds = (int)(rangeSeconds * BUFFER_MULTIPLIER);

        DateTime windowMin = anchorMax.AddSeconds(-rangeSeconds);
        DateTime windowMax = anchorMax;

        // Buffered fetch range (wider than visible)
        DateTime fetchMin = windowMin.AddSeconds(-bufferSeconds);
        DateTime fetchMax = windowMax.AddSeconds(bufferSeconds);

        DateTime now = DateTime.Now;
        if (fetchMax > now)
            fetchMax = now;

        await using var db = await DbFactory.CreateDbContextAsync();

        ChartData = await db.SensorReadings
            .Where(x => x.Time >= fetchMin && x.Time <= fetchMax)
            .OrderBy(x => x.Time)
            .ToListAsync();

        if (ChartData.Any())
            _lastLoadedTime = ChartData.Max(x => x.Time);

        VisibleMin = windowMin;
        VisibleMax = windowMax;
    }

    private async Task SlideWindowTo(DateTime newMax)
    {
        int rangeSeconds = GetRangeSeconds();
        DateTime newMin = newMax.AddSeconds(-rangeSeconds);

        DateTime now = DateTime.Now;
        if (newMax > now)
        {
            newMax = now;
            newMin = newMax.AddSeconds(-rangeSeconds);
        }

        // Determine what we already have in memory
        DateTime memoryMin = ChartData.Any() ? ChartData.Min(x => x.Time) : newMin;
        DateTime memoryMax = ChartData.Any() ? ChartData.Max(x => x.Time) : newMax;

        int bufferSeconds = (int)(rangeSeconds * BUFFER_MULTIPLIER);

        DateTime desiredMin = newMin.AddSeconds(-bufferSeconds);
        DateTime desiredMax = newMax.AddSeconds(bufferSeconds);
        if (desiredMax > now) desiredMax = now;

        bool needsOlderData = desiredMin < memoryMin;
        bool needsNewerData = desiredMax > memoryMax;

        await using var db = await DbFactory.CreateDbContextAsync();

        if (needsOlderData)
        {
            var olderData = await db.SensorReadings
                .Where(x => x.Time >= desiredMin && x.Time < memoryMin)
                .OrderBy(x => x.Time)
                .ToListAsync();

            if (olderData.Any())
                ChartData.InsertRange(0, olderData);
        }

        if (needsNewerData)
        {
            var newerData = await db.SensorReadings
                .Where(x => x.Time > memoryMax && x.Time <= desiredMax)
                .OrderBy(x => x.Time)
                .ToListAsync();

            if (newerData.Any())
            {
                ChartData.AddRange(newerData);
                _lastLoadedTime = newerData.Max(x => x.Time);
            }
        }

        TrimDataAroundWindow(newMin, newMax, bufferSeconds);

        VisibleMin = newMin;
        VisibleMax = newMax;
    }

    private void TrimDataAroundWindow(DateTime windowMin, DateTime windowMax, int bufferSeconds)
    {
        if (!ChartData.Any()) return;

        DateTime trimMin = windowMin.AddSeconds(-bufferSeconds);
        DateTime trimMax = windowMax.AddSeconds(bufferSeconds);

        if (ChartData.Count > MAX_MEMORY_POINTS ||
            ChartData.Any(x => x.Time < trimMin || x.Time > trimMax))
        {
            ChartData = ChartData
                .Where(x => x.Time >= trimMin && x.Time <= trimMax)
                .ToList();
        }
    }

    private List<SensorReading> GetVisibleData()
    {
        if (!VisibleMin.HasValue || !VisibleMax.HasValue)
            return ChartData;

        var padMin = VisibleMin.Value.AddSeconds(-2);
        var padMax = VisibleMax.Value.AddSeconds(2);

        return ChartData
            .Where(x => x.Time >= padMin && x.Time <= padMax)
            .ToList();
    }

    // Returns aggregated series data for a specific tag (groups by base unit)
    private List<AggregatedReading> GetSeriesData(string tag)
    {
        var data = GetVisibleData().Where(x => x.Tag == tag).ToList();
        if (!data.Any()) return new();

        var unit = GetBaseUnit();

        if (unit == ChartCategoryAxisBaseUnit.Seconds)
        {
            return data.Select(x => new AggregatedReading
            {
                Time = x.Time,
                Value = x.Value
            }).ToList();
        }

        Func<DateTime, DateTime> groupKeyFunc = unit switch
        {
            ChartCategoryAxisBaseUnit.Minutes =>
                dt => new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, dt.Minute, 0),
            ChartCategoryAxisBaseUnit.Hours =>
                dt => new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, 0, 0),
            _ => dt => dt
        };

        var groups = data.GroupBy(x => groupKeyFunc(x.Time));

        return groups.Select(g => new AggregatedReading
        {
            Time = g.Key,
            Value = g.Average(x => x.Value)
        })
        .OrderBy(x => x.Time)
        .ToList();
    }

    // ═══════════════════════════════════════════════════════
    //  SLIDING WINDOW NAVIGATION
    // ═══════════════════════════════════════════════════════

    private int GetSlideStepSeconds()
    {
        int range = GetRangeSeconds();
        return Math.Max(1, range / 10);
    }

    private async Task SlideWindowBack()
    {
        if (!VisibleMax.HasValue) return;

        IsLiveMode = false;
        IsPaused = true;
        PausedByInteraction = true;

        int stepSeconds = GetSlideStepSeconds();
        DateTime newMax = VisibleMax.Value.AddSeconds(-stepSeconds);
        _windowAnchorMax = newMax;

        await SlideWindowTo(newMax);
        StateHasChanged();
    }

    private async Task SlideWindowForward()
    {
        if (!VisibleMax.HasValue) return;

        int stepSeconds = GetSlideStepSeconds();
        DateTime newMax = VisibleMax.Value.AddSeconds(stepSeconds);

        DateTime now = DateTime.Now;
        if (newMax >= now.AddSeconds(-1))
        {
            await SnapToLive();
            return;
        }

        _windowAnchorMax = newMax;
        await SlideWindowTo(newMax);
        StateHasChanged();
    }

    private async Task SnapToLive()
    {
        IsLiveMode = true;
        IsPaused = false;
        PausedByInteraction = false;
        _windowAnchorMax = null;

        await LoadDataForWindow(DateTime.Now);
        StateHasChanged();
    }

    // ═══════════════════════════════════════════════════════
    //  MOUSE / WHEEL HANDLERS
    // ═══════════════════════════════════════════════════════

    private async Task OnChartWheel(WheelEventArgs args)
    {
        var now = DateTime.Now;
        if ((now - _lastWheelSlide) < WheelDebounce) return;
        _lastWheelSlide = now;

        if (args.DeltaY > 0)
            await SlideWindowBack();
        else if (args.DeltaY < 0)
            await SlideWindowForward();

        _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    private void OnChartMouseDown(MouseEventArgs args)
    {
        _mouseDownX = args.ClientX;
        _isMouseDown = true;

        if (IsLiveMode && !IsPaused)
        {
            IsPaused = true;
            PausedByInteraction = true;
            IsLiveMode = false;
            _windowAnchorMax = VisibleMax;
        }
    }

    private async Task OnChartMouseMove(MouseEventArgs args)
    {
        if (!_isMouseDown) return;

        var now = DateTime.Now;
        if ((now - _lastDragSlide) < DragDebounce) return;

        double dx = args.ClientX - _mouseDownX;
        if (Math.Abs(dx) < 8) return;

        _lastDragSlide = now;

        if (IsLiveMode && !IsPaused)
        {
            IsPaused = true;
            PausedByInteraction = true;
            IsLiveMode = false;
            _windowAnchorMax = VisibleMax;
        }

        int stepSeconds = GetSlideStepSeconds();
        if (!VisibleMax.HasValue) return;

        DateTime newMax = dx > 0
            ? VisibleMax.Value.AddSeconds(-stepSeconds)
            : VisibleMax.Value.AddSeconds(stepSeconds);

        _windowAnchorMax = newMax;
        _mouseDownX = args.ClientX;

        await SlideWindowTo(newMax);
        StateHasChanged();
    }

    private async Task OnChartMouseUp(MouseEventArgs args)
    {
        _isMouseDown = false;
        if (IsPaused) _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnChartMouseLeave(MouseEventArgs args)
    {
        _isMouseDown = false;
        if (IsPaused) _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    // ═══════════════════════════════════════════════════════
    //  PAUSE / RESUME / TIMER
    // ═══════════════════════════════════════════════════════

    private async Task TogglePauseResume()
    {
        if (IsPaused)
            await SnapToLive();
        else
        {
            IsPaused = true;
            PausedByInteraction = false;
            IsLiveMode = false;
            _windowAnchorMax = VisibleMax;
        }
        StateHasChanged();
    }

    private void StartTimer()
    {
        _timer = new System.Timers.Timer(RefreshIntervalMs);

        _timer.Elapsed += async (s, e) =>
        {
            if (!IsLiveMode || IsPaused) return;

            await InvokeAsync(async () =>
            {
                try
                {
                    await using var db = await DbFactory.CreateDbContextAsync();

                    var newData = await db.SensorReadings
                        .Where(x => x.Time > _lastLoadedTime)
                        .OrderBy(x => x.Time)
                        .ToListAsync();

                    if (newData.Any())
                    {
                        ChartData.AddRange(newData);
                        _lastLoadedTime = newData.Max(x => x.Time);
                    }

                    var latest = ChartData.Any()
                        ? ChartData.Max(x => x.Time)
                        : DateTime.Now;

                    int rangeSeconds = GetRangeSeconds();
                    VisibleMax = latest;
                    VisibleMin = latest.AddSeconds(-rangeSeconds);

                    int bufferSeconds = (int)(rangeSeconds * BUFFER_MULTIPLIER);
                    TrimDataAroundWindow(VisibleMin.Value, VisibleMax.Value, bufferSeconds);

                    StateHasChanged();
                }
                catch { }
            });
        };

        _timer.AutoReset = true;
        _timer.Start();
    }

    private void UpdateTimerInterval()
    {
        if (_timer == null) return;
        _timer.Stop();
        _timer.Interval = _refreshIntervalMs;
        _timer.Start();
    }

    // ═══════════════════════════════════════════════════════
    //  RANGE CHANGE
    // ═══════════════════════════════════════════════════════

    private async Task ChangeRange(string range)
    {
        SelectedRange = range;
        UpdateTimerInterval();

        if (IsLiveMode)
            await LoadDataForWindow(DateTime.Now);
        else if (_windowAnchorMax.HasValue)
            await LoadDataForWindow(_windowAnchorMax.Value);
        else
            await LoadDataForWindow(DateTime.Now);

        StateHasChanged();
    }

    // ═══════════════════════════════════════════════════════
    //  LEGEND
    // ═══════════════════════════════════════════════════════

    private void OnLegendItemClick(ChartLegendItemClickEventArgs args)
    {
        var seriesDisplayName = args.Text;
        if (string.IsNullOrEmpty(seriesDisplayName)) return;

        var trendSuffix = " Trend";
        var isTrend = seriesDisplayName.EndsWith(trendSuffix);
        var baseDisplayName = isTrend ? seriesDisplayName[..^trendSuffix.Length] : seriesDisplayName;

        // Try to map display name back to a tag key (SeriesConfigs key)
        var match = SeriesConfigs.FirstOrDefault(kv => (kv.Value.Name ?? kv.Key) == baseDisplayName);
        string tagKey = null;

        if (!match.Equals(default(KeyValuePair<string, SeriesConfiguration>)) && match.Value != null)
        {
            tagKey = match.Key;
        }
        else if (SeriesConfigs.ContainsKey(baseDisplayName))
        {
            // fallback: displayName is the tag key
            tagKey = baseDisplayName;
        }

        if (string.IsNullOrEmpty(tagKey)) return;

        if (isTrend)
        {
            var trendKey = $"{tagKey}_trend";
            if (HiddenSeries.Contains(trendKey))
                HiddenSeries.Remove(trendKey);
            else
                HiddenSeries.Add(trendKey);
        }
        else
        {
            if (HiddenSeries.Contains(tagKey))
            {
                HiddenSeries.Remove(tagKey);
                if (SeriesConfigs.ContainsKey(tagKey))
                    SeriesConfigs[tagKey].IsHidden = false;
            }
            else
            {
                HiddenSeries.Add(tagKey);
                if (SeriesConfigs.ContainsKey(tagKey))
                    SeriesConfigs[tagKey].IsHidden = true;

                // also hide trendline if present
                if (SeriesConfigs.TryGetValue(tagKey, out var cfg) && cfg.ShowTrendline)
                    HiddenSeries.Add($"{tagKey}_trend");
            }
        }

        StateHasChanged();
    }

    private void ShowAllSeries()
    {
        HiddenSeries.Clear();
        foreach (var cfgKvp in SeriesConfigs)
        {
            cfgKvp.Value.IsHidden = false;
        }
        StateHasChanged();
    }

    private void HideAllSeries()
    {
        foreach (var tag in SelectedTags)
        {
            var cfg = GetSeriesConfig(tag);
            HiddenSeries.Add(tag);
            cfg.IsHidden = true;

            if (cfg.ShowTrendline)
                HiddenSeries.Add($"{tag}_trend");
        }
        StateHasChanged();
    }


    // ═══════════════════════════════════════════════════════
    //  PLOT BANDS
    // ═══════════════════════════════════════════════════════

    private void AddPlotBand()
    {
        var defaultAxis = SelectedTags.FirstOrDefault() ?? GetDistinctYAxes().FirstOrDefault() ?? "";

        PlotBands.Add(new PlotBandConfig
        {
            AxisName = defaultAxis,
            From = 0,
            To = 100,
            Color = "#ff6358",
            Opacity = 0.15,
        });
        _chartKey++;
        StateHasChanged();
    }

    private void RemovePlotBand(int index)
    {
        if (index < 0 || index >= PlotBands.Count) return;
        PlotBands.RemoveAt(index);
        _chartKey++;
        StateHasChanged();
    }

    private void ResetToDefaults()
    {
        // Preserve existing axis keys and titles so user-created axes are not deleted
        var preservedAxisTitles = YAxisConfigs.ToDictionary(kv => kv.Key, kv => kv.Value.Title);

        // Preserve existing series -> axis mappings so mappings survive reset
        var seriesAxisMap = SeriesConfigs.ToDictionary(kv => kv.Key, kv => kv.Value.AxisName);

        // Clear series-level configuration then recreate defaults for the currently selected tags
        SeriesConfigs.Clear();
        SeriesRenameBuffers.Clear();

        var defaultAxis = YAxisConfigs.Keys.FirstOrDefault() ?? "Axis 1";
        int i = 0;
        foreach (var tag in SelectedTags)
        {
            i++;
            var axisName = seriesAxisMap.TryGetValue(tag, out var mapped) && !string.IsNullOrEmpty(mapped)
                ? mapped
                : defaultAxis;

            SeriesConfigs[tag] = new SeriesConfiguration
            {
                Name = "", // Reset display name so UI shows tag by default
                ChartType = "Line",
                Color = GetDefaultColor(i),
                LineStyle = "Solid",
                LineWidth = 2,
                IsSmooth = true,
                ShowMarkers = false,
                MarkerType = "Circle",
                MarkerSize = 6,
                AreaOpacity = 0.5,
                BarGap = 1.5,
                BorderWidth = 0,
                BorderColor = "#000000",
                ShowDataLabels = false,
                DataLabelFormat = "N0",
                DataLabelPosition = "Above",
                AxisName = axisName, // preserve mapping
                ShowTrendline = false,
                TrendlineType = "Linear",
                TrendlineColor = "#999999",
                IsHidden = false,
                IsExpanded = false
            };
        }

        // Rebuild YAxisConfigs keeping the axis entries (names/titles) but reset their settings
        var existingAxisKeys = YAxisConfigs.Keys.ToList();
        YAxisConfigs.Clear();
        foreach (var key in existingAxisKeys)
        {
            var title = preservedAxisTitles.TryGetValue(key, out var t) ? t : key;
            YAxisConfigs[key] = new YAxisConfiguration
            {
                Name = key,
                Title = title,
                Visible = true,
                Position = "Left",
                Min = null,
                Max = null,
                AxisColor = "#000000",
                ShowMajorTicks = true,
                MajorUnit = null,
                ShowMajorGridLines = true,
                MajorGridDash = "Solid",
                MajorGridColor = "#dddddd",
                ShowMinorTicks = false,
                MinorUnit = null,
                IsExpanded = true
            };
        }

        // Preserve axis order
        YAxisOrder = existingAxisKeys.ToList();

        // Clear other UI / chart state
        PlotBands.Clear();
        HiddenSeries.Clear();
        XAxisConfig = new();
        SelectedRange = "30s";
        ShowLegend = true;
        ShowTooltip = true;
        SharedTooltip = true;
        IsStacked = false;
        ShowMajorTicks = true;
        ShowMinorTicks = false;
        MajorTickStep = 1;
        MinorTickStep = 1;
        CategoryLabelRotation = -45;
        ChartHeight = 550;
        ChartBackground = "white";
        TooltipBackground = "#e6e6e6";
        EnableTransitions = false;
        CustomChartTitle = "";
        RefreshIntervalMs = 100;

        ChartMarginTop = 8;
        ChartMarginRight = 8;
        ChartMarginBottom = 8;
        ChartMarginLeft = 8;
        PlotAreaPadding = 8;
        TitleAlignment = "Center";

        // reset global y-axis sync
        SyncYAxisMinMax = false;
        GlobalYAxisMin = null;
        GlobalYAxisMax = null;

        // Ensure at least one axis remains
        if (!YAxisConfigs.Any())
        {
            YAxisConfigs["Axis 1"] = new YAxisConfiguration { Name = "Axis 1", Title = "Axis 1" };
            if (!YAxisOrder.Contains("Axis 1")) YAxisOrder.Add("Axis 1");
        }

        _chartKey++;
        StateHasChanged();
    }

