    private string GetXAxisTitle()
    {
        if (string.IsNullOrEmpty(SelectedXAxis)) return "";

        var unitName = GetBaseUnit() switch
        {
            ChartCategoryAxisBaseUnit.Seconds => "Seconds",
            ChartCategoryAxisBaseUnit.Minutes => "Minutes",
            ChartCategoryAxisBaseUnit.Hours => "Hours",
            _ => ""
        };

        return $"Time — {SelectedRange} (in {unitName})";
    }

    private ChartLegendPosition GetLegendPosition() => SelectedLegendPosition switch
    {
        "Top" => ChartLegendPosition.Top,
        "Bottom" => ChartLegendPosition.Bottom,
        "Left" => ChartLegendPosition.Left,
        _ => ChartLegendPosition.Right
    };

    private string GetDynamicChartTitle()
    {
        if (!string.IsNullOrEmpty(CustomChartTitle))
            return CustomChartTitle;

        if (!SelectedYAxes.Any())
            return "Live Trend Chart";

        var yDescriptions = SelectedYAxes
            .Select(y =>
            {
                var cfg = GetSeriesConfig(y);
                var visibility = cfg.IsHidden ? " [Hidden]" : "";
                return $"{y} ({cfg.ChartType}){visibility}";
            });

        string stateText = (IsLiveMode && !IsPaused) ? "● Live"
            : (IsPaused && PausedByInteraction) ? "⚠ Auto-Paused"
            : IsPaused ? "⏸ Paused"
            : "📜 History";

        int visibleCount = SelectedYAxes.Count(y => !GetSeriesConfig(y).IsHidden && GetYAxisConfig(y).Visible);
        int totalCount = SelectedYAxes.Count;

        return $"{string.Join(", ", yDescriptions)} | {SelectedRange} | {stateText} | {visibleCount}/{totalCount}";
    }

    private void OpenChart() => ShowWindow = true;

    // Auto set global Y min/max from currently visible aggregated data
    private void AutoSetGlobalYRange()
    {
        var data = GetAggregatedVisibleData();
        if (!data.Any() || !SelectedYAxes.Any())
            return;

        double min = double.MaxValue;
        double max = double.MinValue;

        foreach (var row in data)
        {
            foreach (var y in SelectedYAxes)
            {
                var prop = row.GetType().GetProperty(y);
                if (prop == null) continue;
                var val = prop.GetValue(row);
                if (val == null) continue;
                if (double.TryParse(val.ToString(), out var d))
                {
                    if (d < min) min = d;
                    if (d > max) max = d;
                }
            }
        }

        if (min == double.MaxValue || max == double.MinValue) return;

        GlobalYAxisMin = min;
        GlobalYAxisMax = max;
        StateHasChanged();
    }

    // ═══════════════════════════════════════════════════════
    //  Populate fields dynamically
    // ═══════════════════════════════════════════════════════

    private void PopulateFieldOptionsFromModel()
    {
        XAxisOptions.Clear();
        YAxisOptions.Clear();

        var props = typeof(SensorReading).GetProperties(System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance);

        foreach (var p in props)
        {
            // Skip internal/identifier fields
            if (string.Equals(p.Name, "Id", StringComparison.OrdinalIgnoreCase))
                continue;

            var underlying = Nullable.GetUnderlyingType(p.PropertyType) ?? p.PropertyType;

            if (underlying == typeof(DateTime))
            {
                XAxisOptions.Add(new FieldOption { Text = p.Name, Value = p.Name });
            }
            else if (IsNumericType(underlying))
            {
                YAxisOptions.Add(new FieldOption { Text = p.Name, Value = p.Name });
            }
        }

        // set sensible defaults if not already set
        // if (string.IsNullOrEmpty(SelectedXAxis) && XAxisOptions.Any())
        //     SelectedXAxis = XAxisOptions[0].Value;


    }

    private static bool IsNumericType(Type t)
    {
        var numericTypes = new HashSet<Type>
        {
            typeof(byte),
            typeof(sbyte),
            typeof(short),
            typeof(ushort),
            typeof(int),
            typeof(uint),
            typeof(long),
            typeof(ulong),
            typeof(float),
            typeof(double),
            typeof(decimal)
        };

        return numericTypes.Contains(t);
    }

    // ═══════════════════════════════════════════════════════

    public void Dispose()
    {
        if (_timer != null)
        {
            _timer.Stop();
            _timer.Dispose();
        }
    }
}

