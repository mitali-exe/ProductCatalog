    private object[] GetCategoryAxisCrossings()
    {
        var axes = GetDistinctYAxes();
        var data = GetAggregatedVisibleData();
        int count = Math.Max(1, data.Count);
        var crossings = new List<object>();

        foreach (var axisId in axes)
        {
            var cfg = GetYAxisConfig(axisId);
            if (cfg.Position == "Right")
            {
                crossings.Add(count - 1);
            }
            else
            {
                crossings.Add(0);
            }
        }

        // crossings.Add(double.MinValue);

        return crossings.ToArray();
    }


    // ═══════════════════════════════════════════════════════
    //  DATA LOADING
    // ═══════════════════════════════════════════════════════

    private async Task LoadDataForWindow(DateTime anchorMax)
    {
        int rangeSeconds = GetRangeSeconds();
        int bufferSeconds = (int)(rangeSeconds * BUFFER_MULTIPLIER);

        DateTime windowMin = anchorMax.AddSeconds(-rangeSeconds);
        DateTime windowMax = anchorMax;

        // Buffered fetch range (wider than visible)
        DateTime fetchMin = windowMin.AddSeconds(-bufferSeconds);
        DateTime fetchMax = windowMax.AddSeconds(bufferSeconds);

        DateTime now = DateTime.Now;
        if (fetchMax > now)
            fetchMax = now;

        await using var db = await DbFactory.CreateDbContextAsync();

        ChartData = await db.SensorReadings
            .Where(x => x.Time >= fetchMin && x.Time <= fetchMax)
            .OrderBy(x => x.Time)
            .ToListAsync();

        if (ChartData.Any())
            _lastLoadedTime = ChartData.Max(x => x.Time);

        VisibleMin = windowMin;
        VisibleMax = windowMax;
    }

    private async Task SlideWindowTo(DateTime newMax)
    {
        int rangeSeconds = GetRangeSeconds();
        DateTime newMin = newMax.AddSeconds(-rangeSeconds);

        DateTime now = DateTime.Now;
        if (newMax > now)
        {
            newMax = now;
            newMin = newMax.AddSeconds(-rangeSeconds);
        }

        // Determine what we already have in memory
        DateTime memoryMin = ChartData.Any() ? ChartData.Min(x => x.Time) : newMin;
        DateTime memoryMax = ChartData.Any() ? ChartData.Max(x => x.Time) : newMax;

        int bufferSeconds = (int)(rangeSeconds * BUFFER_MULTIPLIER);

        DateTime desiredMin = newMin.AddSeconds(-bufferSeconds);
        DateTime desiredMax = newMax.AddSeconds(bufferSeconds);
        if (desiredMax > now) desiredMax = now;

        bool needsOlderData = desiredMin < memoryMin;
        bool needsNewerData = desiredMax > memoryMax;

        await using var db = await DbFactory.CreateDbContextAsync();

        if (needsOlderData)
        {
            var olderData = await db.SensorReadings
                .Where(x => x.Time >= desiredMin && x.Time < memoryMin)
                .OrderBy(x => x.Time)
                .ToListAsync();

            if (olderData.Any())
                ChartData.InsertRange(0, olderData);
        }

        if (needsNewerData)
        {
            var newerData = await db.SensorReadings
                .Where(x => x.Time > memoryMax && x.Time <= desiredMax)
                .OrderBy(x => x.Time)
                .ToListAsync();

            if (newerData.Any())
            {
                ChartData.AddRange(newerData);
                _lastLoadedTime = newerData.Max(x => x.Time);
            }
        }

        TrimDataAroundWindow(newMin, newMax, bufferSeconds);

        VisibleMin = newMin;
        VisibleMax = newMax;
    }

    private void TrimDataAroundWindow(DateTime windowMin, DateTime windowMax, int bufferSeconds)
    {
        if (!ChartData.Any()) return;

        DateTime trimMin = windowMin.AddSeconds(-bufferSeconds);
        DateTime trimMax = windowMax.AddSeconds(bufferSeconds);

        if (ChartData.Count > MAX_MEMORY_POINTS ||
            ChartData.Any(x => x.Time < trimMin || x.Time > trimMax))
        {
            ChartData = ChartData
                .Where(x => x.Time >= trimMin && x.Time <= trimMax)
                .ToList();
        }
    }

    private List<SensorReading> GetVisibleData()
    {
        if (!VisibleMin.HasValue || !VisibleMax.HasValue)
            return ChartData;

        var padMin = VisibleMin.Value.AddSeconds(-2);
        var padMax = VisibleMax.Value.AddSeconds(2);

        return ChartData
            .Where(x => x.Time >= padMin && x.Time <= padMax)
            .ToList();
    }

    private List<AggregatedReading> GetAggregatedVisibleData()
    {
        var data = GetVisibleData();
        if (!data.Any()) return new();

        var unit = GetBaseUnit();

        if (unit == ChartCategoryAxisBaseUnit.Seconds)
        {
            return data.Select(x => new AggregatedReading
            {
                Time = x.Time,
                Temperature = x.Temperature,
                Pressure = x.Pressure,
                Humidity = x.Humidity,
                Voltage = x.Voltage
            }).ToList();
        }

        Func<DateTime, DateTime> groupKeyFunc = unit switch
        {
            ChartCategoryAxisBaseUnit.Minutes =>
                dt => new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, dt.Minute, 0),
            ChartCategoryAxisBaseUnit.Hours =>
                dt => new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, 0, 0),
            _ => dt => dt
        };

        var groups = data.GroupBy(x => groupKeyFunc(x.Time));

        return groups.Select(g => new AggregatedReading
        {
            Time = g.Key,
            // average sensor readings for grouped buckets
            Temperature = g.Average(x => x.Temperature),
            Pressure = g.Average(x => x.Pressure),
            Humidity = g.Average(x => x.Humidity),
            Voltage = g.Average(x => x.Voltage)
        })
        .OrderBy(x => x.Time)
        .ToList();
    }

    // ═══════════════════════════════════════════════════════
    //  SLIDING WINDOW NAVIGATION
    // ═══════════════════════════════════════════════════════

    private int GetSlideStepSeconds()
    {
        int range = GetRangeSeconds();
        return Math.Max(1, range / 10);
    }

    private async Task SlideWindowBack()
    {
        if (!VisibleMax.HasValue) return;

        IsLiveMode = false;
        IsPaused = true;
        PausedByInteraction = true;

        int stepSeconds = GetSlideStepSeconds();
        DateTime newMax = VisibleMax.Value.AddSeconds(-stepSeconds);
        _windowAnchorMax = newMax;

        await SlideWindowTo(newMax);
        StateHasChanged();
    }

    private async Task SlideWindowForward()
    {
        if (!VisibleMax.HasValue) return;

        int stepSeconds = GetSlideStepSeconds();
        DateTime newMax = VisibleMax.Value.AddSeconds(stepSeconds);

        DateTime now = DateTime.Now;
        if (newMax >= now.AddSeconds(-1))
        {
            await SnapToLive();
            return;
        }

        _windowAnchorMax = newMax;
        await SlideWindowTo(newMax);
        StateHasChanged();
    }

    private async Task SnapToLive()
    {
        IsLiveMode = true;
        IsPaused = false;
        PausedByInteraction = false;
        _windowAnchorMax = null;

        await LoadDataForWindow(DateTime.Now);
        StateHasChanged();
    }

    // ═══════════════════════════════════════════════════════
    //  MOUSE / WHEEL HANDLERS
    // ═══════════════════════════════════════════════════════

    private async Task OnChartWheel(WheelEventArgs args)
    {
        var now = DateTime.Now;
        if ((now - _lastWheelSlide) < WheelDebounce) return;
        _lastWheelSlide = now;

        if (args.DeltaY > 0)
            await SlideWindowBack();
        else if (args.DeltaY < 0)
            await SlideWindowForward();

        _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    private void OnChartMouseDown(MouseEventArgs args)
    {
        _mouseDownX = args.ClientX;
        _isMouseDown = true;

        if (IsLiveMode && !IsPaused)
        {
            IsPaused = true;
            PausedByInteraction = true;
            IsLiveMode = false;
            _windowAnchorMax = VisibleMax;
        }
    }

    private async Task OnChartMouseMove(MouseEventArgs args)
    {
        if (!_isMouseDown) return;

        var now = DateTime.Now;
        if ((now - _lastDragSlide) < DragDebounce) return;

        double dx = args.ClientX - _mouseDownX;
        if (Math.Abs(dx) < 8) return;

        _lastDragSlide = now;

        if (IsLiveMode && !IsPaused)
        {
            IsPaused = true;
            PausedByInteraction = true;
            IsLiveMode = false;
            _windowAnchorMax = VisibleMax;
        }

        int stepSeconds = GetSlideStepSeconds();
        if (!VisibleMax.HasValue) return;

        DateTime newMax = dx > 0
            ? VisibleMax.Value.AddSeconds(-stepSeconds)
            : VisibleMax.Value.AddSeconds(stepSeconds);

        _windowAnchorMax = newMax;
        _mouseDownX = args.ClientX;

        await SlideWindowTo(newMax);
        StateHasChanged();
    }

    private async Task OnChartMouseUp(MouseEventArgs args)
    {
        _isMouseDown = false;
        if (IsPaused) _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnChartMouseLeave(MouseEventArgs args)
    {
        _isMouseDown = false;
        if (IsPaused) _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    // ═══════════════════════════════════════════════════════
    //  PAUSE / RESUME / TIMER
    // ═══════════════════════════════════════════════════════

    private async Task TogglePauseResume()
    {
        if (IsPaused)
            await SnapToLive();
        else
        {
            IsPaused = true;
            PausedByInteraction = false;
            IsLiveMode = false;
            _windowAnchorMax = VisibleMax;
        }
        StateHasChanged();
    }

    private void StartTimer()
    {
        _timer = new System.Timers.Timer(RefreshIntervalMs);

        _timer.Elapsed += async (s, e) =>
        {
            if (!IsLiveMode || IsPaused) return;

            await InvokeAsync(async () =>
            {
                try
                {
                    await using var db = await DbFactory.CreateDbContextAsync();

                    var newData = await db.SensorReadings
                        .Where(x => x.Time > _lastLoadedTime)
                        .OrderBy(x => x.Time)
                        .ToListAsync();

                    if (newData.Any())
                    {
                        ChartData.AddRange(newData);
                        _lastLoadedTime = newData.Max(x => x.Time);
                    }

                    var latest = ChartData.Any()
                        ? ChartData.Max(x => x.Time)
                        : DateTime.Now;

                    int rangeSeconds = GetRangeSeconds();
                    VisibleMax = latest;
                    VisibleMin = latest.AddSeconds(-rangeSeconds);

                    int bufferSeconds = (int)(rangeSeconds * BUFFER_MULTIPLIER);
                    TrimDataAroundWindow(VisibleMin.Value, VisibleMax.Value, bufferSeconds);

                    StateHasChanged();
                }
                catch { }
            });
        };

        _timer.AutoReset = true;
        _timer.Start();
    }

    private void UpdateTimerInterval()
    {
        if (_timer == null) return;
        _timer.Stop();
        _timer.Interval = _refreshIntervalMs;
        _timer.Start();
    }

    // ═══════════════════════════════════════════════════════
    //  RANGE CHANGE
    // ═══════════════════════════════════════════════════════

    private async Task ChangeRange(string range)
    {
        SelectedRange = range;
        UpdateTimerInterval();

        if (IsLiveMode)
            await LoadDataForWindow(DateTime.Now);
        else if (_windowAnchorMax.HasValue)
            await LoadDataForWindow(_windowAnchorMax.Value);
        else
            await LoadDataForWindow(DateTime.Now);

        StateHasChanged();
    }

    // ═══════════════════════════════════════════════════════
    //  LEGEND
    // ═══════════════════════════════════════════════════════

    private void OnLegendItemClick(ChartLegendItemClickEventArgs args)
    {
        var seriesName = args.Text;
        if (string.IsNullOrEmpty(seriesName)) return;

        if (HiddenSeries.Contains(seriesName))
        {
            HiddenSeries.Remove(seriesName);
            if (SeriesConfigs.ContainsKey(seriesName))
                SeriesConfigs[seriesName].IsHidden = false;
        }
        else
        {
            HiddenSeries.Add(seriesName);
            if (SeriesConfigs.ContainsKey(seriesName))
                SeriesConfigs[seriesName].IsHidden = true;
        }

        StateHasChanged();
    }

    private void ShowAllSeries()
    {
        HiddenSeries.Clear();
        foreach (var cfg in SeriesConfigs.Values)
            cfg.IsHidden = false;
        StateHasChanged();
    }

    private void HideAllSeries()
    {
        foreach (var y in SelectedYAxes)
        {
            HiddenSeries.Add(y);
            GetSeriesConfig(y).IsHidden = true;

            if (GetSeriesConfig(y).ShowTrendline)
                HiddenSeries.Add($"{y} Trend");
        }
        StateHasChanged();
    }


    // ═══════════════════════════════════════════════════════
    //  PLOT BANDS
    // ═══════════════════════════════════════════════════════

    private void AddPlotBand()
    {
        PlotBands.Add(new PlotBandConfig
        {
            From = 0,
            To = 100,
            Color = "#ff6358",
            Opacity = 0.15,
            Label = $"Band {PlotBands.Count + 1}"
        });
    }

    private void ResetToDefaults()
    {
        SeriesConfigs.Clear();
        YAxisConfigs.Clear();
        PlotBands.Clear();
        HiddenSeries.Clear();
        XAxisConfig = new();
        SelectedRange = "30s";
        ShowLegend = true;
        ShowTooltip = true;
        SharedTooltip = true;
        IsStacked = false;
        ShowMajorTicks = true;
        ShowMinorTicks = false;
        MajorTickStep = 1;
        MinorTickStep = 1;
        CategoryLabelRotation = -45;
        ChartHeight = 550;
        ChartBackground = "white";
        TooltipBackground = "#e6e6e6";
        EnableTransitions = false;
        CustomChartTitle = "";
        RefreshIntervalMs = 100;

        // reset layout
        ChartMarginTop = 8;
        ChartMarginRight = 8;
        ChartMarginBottom = 8;
        ChartMarginLeft = 8;
        PlotAreaPadding = 8;
        TitleAlignment = "Center";

        // reset global y-axis sync
        SyncYAxisMinMax = false;
        GlobalYAxisMin = null;
        GlobalYAxisMax = null;

        StateHasChanged();
    }

