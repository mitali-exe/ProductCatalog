    private SeriesConfiguration GetSeriesConfig(string name)
    {
        if (!SeriesConfigs.ContainsKey(name))
        {
            var index = SelectedYAxes.IndexOf(name);
            SeriesConfigs[name] = new SeriesConfiguration
            {
                Name = name,
                Color = GetDefaultColor(index),
                ChartType = "Line"
            };
        }
        return SeriesConfigs[name];
    }

    private void SetSeriesChartType(string name, string type)
    {
        GetSeriesConfig(name).ChartType = type;
        _chartKey++;
        StateHasChanged();
    }

    private void SetSeriesColor(string name, string color)
    {
        GetSeriesConfig(name).Color = color ?? "#116fd4";
        _chartKey++;
        StateHasChanged();
    }

    private void ToggleSeriesVisibility(string name)
    {
        var cfg = GetSeriesConfig(name);
        cfg.IsHidden = !cfg.IsHidden;

        if (cfg.IsHidden)
            HiddenSeries.Add(name);
        else
            HiddenSeries.Remove(name);

        _chartKey++;
        StateHasChanged();
    }

    private void ToggleSeriesExpanded(string name)
    {
        var cfg = GetSeriesConfig(name);
        cfg.IsExpanded = !cfg.IsExpanded;
    }

    private void MoveSeriesUp(string name)
    {
        var idx = SelectedYAxes.IndexOf(name);
        if (idx <= 0) return;
        SelectedYAxes.RemoveAt(idx);
        SelectedYAxes.Insert(idx - 1, name);
        _chartKey++;
        StateHasChanged();
    }

    private void MoveSeriesDown(string name)
    {
        var idx = SelectedYAxes.IndexOf(name);
        if (idx < 0 || idx >= SelectedYAxes.Count - 1) return;
        SelectedYAxes.RemoveAt(idx);
        SelectedYAxes.Insert(idx + 1, name);
        _chartKey++;
        StateHasChanged();
    }

    private void SetYAxisPosition(string axisId, string position)
    {
        var pos = position ?? "Left";
        var yConfig = GetYAxisConfig(axisId);
        yConfig.Position = pos;

        if (SeriesConfigs.ContainsKey(axisId))
            SeriesConfigs[axisId].AxisAssignment = pos == "Right" ? "Right" : "Left";

        _chartKey++;
        StateHasChanged();
    }

    private void SetYAxisVisible(string axisId, bool visible)
    {
        var yConfig = GetYAxisConfig(axisId);
        yConfig.Visible = visible;

        // If axis is hidden, hide its series (and trendline) so they are not rendered.
        if (!visible)
        {
            if (SeriesConfigs.TryGetValue(axisId, out var sCfg))
            {
                sCfg.IsHidden = true;
                HiddenSeries.Add(axisId);

                if (sCfg.ShowTrendline)
                    HiddenSeries.Add($"{axisId} Trend");
            }
        }
        else
        {
            // When making axis visible again, restore series visibility only if it was auto-hidden by axis hide.
            if (SeriesConfigs.TryGetValue(axisId, out var sCfg))
            {
                if (HiddenSeries.Contains(axisId))
                {
                    HiddenSeries.Remove(axisId);
                    sCfg.IsHidden = false;
                }

                var trendName = $"{axisId} Trend";
                if (HiddenSeries.Contains(trendName) && sCfg.ShowTrendline)
                    HiddenSeries.Remove(trendName);
            }
        }

        _chartKey++;
        StateHasChanged();
    }

