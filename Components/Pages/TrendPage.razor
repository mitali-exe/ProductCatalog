    //  AXIS HELPERS
    // ═══════════════════════════════════════════════════════

    private ChartCategoryAxisBaseUnit GetBaseUnit() => SelectedRange switch
    {
        "30s" => ChartCategoryAxisBaseUnit.Seconds,
        "1m" => ChartCategoryAxisBaseUnit.Seconds,
        "5m" => ChartCategoryAxisBaseUnit.Minutes,
        "10m" => ChartCategoryAxisBaseUnit.Minutes,
        "30m" => ChartCategoryAxisBaseUnit.Minutes,
        "1h" => ChartCategoryAxisBaseUnit.Minutes,
        "6h" => ChartCategoryAxisBaseUnit.Hours,
        "12h" => ChartCategoryAxisBaseUnit.Hours,
        "1d" => ChartCategoryAxisBaseUnit.Hours,
        _ => ChartCategoryAxisBaseUnit.Seconds
    };

    private int GetAutoBaseUnitStep() => 1;

    private string GetAxisLabelFormat() => SelectedRange switch
    {
        "30s" => "HH:mm:ss",
        "1m" => "HH:mm:ss",
        "5m" => "HH:mm",
        "10m" => "HH:mm",
        "30m" => "HH:mm",
        "1h" => "HH:mm",
        "6h" => "HH:mm",
        "12h" => "HH:mm",
        "1d" => "dd-MM HH:mm",
        _ => "HH:mm:ss"
    };

    private string GetTooltipTimeFormat() => SelectedRange switch
    {
        "30s" => "dd-MM-yyyy HH:mm:ss.fff",
        "1m" => "dd-MM-yyyy HH:mm:ss.fff",
        "5m" => "dd-MM-yyyy HH:mm:ss",
        "10m" => "dd-MM-yyyy HH:mm:ss",
        "30m" => "dd-MM-yyyy HH:mm:ss",
        "1h" => "dd-MM-yyyy HH:mm:ss",
        "6h" => "dd-MM-yyyy HH:mm",
        "12h" => "dd-MM-yyyy HH:mm",
        "1d" => "dd-MM-yyyy HH:mm",
        _ => "dd-MM-yyyy HH:mm:ss.fff"
    };

    private int GetRangeSeconds() => SelectedRange switch
    {
        "30s" => 30,
        "1m" => 60,
        "5m" => 300,
        "10m" => 600,
        "30m" => 1800,
        "1h" => 3600,
        "6h" => 21600,
        "12h" => 43200,
        "1d" => 86400,
        _ => 30
    };

    private string GetXAxisTitle()
    {
        var unitName = GetBaseUnit() switch
        {
            ChartCategoryAxisBaseUnit.Seconds => "Seconds",
            ChartCategoryAxisBaseUnit.Minutes => "Minutes",
            ChartCategoryAxisBaseUnit.Hours => "Hours",
            _ => ""
        };

        return $"Time — {SelectedRange} (in {unitName})";
    }

    private ChartLegendPosition GetLegendPosition() => SelectedLegendPosition switch
    {
        "Top" => ChartLegendPosition.Top,
        "Bottom" => ChartLegendPosition.Bottom,
        "Left" => ChartLegendPosition.Left,
        _ => ChartLegendPosition.Right
    };

    private void OpenChart() => ShowWindow = true;

    // Auto set global Y min/max from currently visible aggregated data across selected tags
    private void AutoSetGlobalYRange()
    {
        var allVals = new List<double>();
        foreach (var tag in SelectedTags)
        {
            var series = GetSeriesData(tag);
            allVals.AddRange(series.Select(s => s.Value));
        }

        if (!allVals.Any()) return;

        GlobalYAxisMin = allVals.Min();
        GlobalYAxisMax = allVals.Max();
        StateHasChanged();
    }

    // Helper to produce options for axis dropdowns
    private List<FieldOption> GetYAxisOptions()
    {
        return GetDistinctYAxes().Select(a => new FieldOption { Text = a, Value = a }).ToList();
    }


    private static bool IsNumericType(Type t)
    {
        var numericTypes = new HashSet<Type>
        {
            typeof(byte),
            typeof(sbyte),
            typeof(short),
            typeof(ushort),
            typeof(int),
            typeof(uint),
            typeof(long),
            typeof(ulong),
            typeof(float),
            typeof(double),
            typeof(decimal)
        };

        return numericTypes.Contains(t);
    }

    public void Dispose()
    {
        if (_timer != null)
        {
            _timer.Stop();
            _timer.Dispose();
        }
    }
}

